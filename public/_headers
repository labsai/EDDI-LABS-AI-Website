# Security Headers — Cloudflare Pages / Workers (unified platform)
# Required for OpenSSF Best Practices Gold badge [hardened_site] criterion.
#
# Applied to all routes. Cloudflare parses this file from the build output
# directory and injects these headers into every static asset response.
#
# CSP audited against: HubSpot forms embed v2, Umami analytics,
# Google Analytics GA4, shields.io badges, GitHub Actions badges.
# If the HubSpot form breaks, check browser DevTools console for
# CSP violations and add the blocked domain.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.hsforms.net https://js.hs-scripts.com https://js.hs-analytics.net https://js.hscollectedforms.net https://cloud.umami.is https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://img.shields.io https://github.com https://forms.hsforms.com https://track.hubspot.com https://www.google-analytics.com; font-src 'self' data:; connect-src 'self' https://forms.hubspot.com https://forms.hsforms.com https://forms-na1.hsforms.com https://api.hubapi.com https://cloud.umami.is https://www.google-analytics.com; frame-src https://forms.hsforms.com https://js.hsforms.net; object-src 'none'; base-uri 'self'; form-action 'self' https://forms.hubspot.com https://forms.hsforms.com
