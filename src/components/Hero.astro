---
import { Image } from 'astro:assets';
const PAGE_TITLE_ID = '_top';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

const imageAttrs = {
	loading: 'eager' as const,
	decoding: 'async' as const,
	width: 500,
	height: 500,
	alt: image?.alt || '',
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;
if (image) {
	if ('file' in image) {
		darkImage = image.file;
	} else if ('dark' in image) {
		darkImage = image.dark;
		lightImage = image.light;
	} else {
		rawHtml = image.html;
	}
}
---

<div class="hero hero-gradient">
	<div class="hero-inner">
		<div class="hero-content slide-up">
			<h1 id={PAGE_TITLE_ID} data-page-title set:html={title} class="hero-title" />
			{tagline && <p class="hero-tagline" set:html={tagline} />}
			
			{
				actions.length > 0 && (
					<div class="hero-actions">
						{actions.map(
							({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => {
								const isPrimary = variant === 'primary' || !variant;
								return (
									<a
										href={href}
										class:list={[
											'hero-btn',
											isPrimary ? 'hero-btn-primary glow-accent' : 'hero-btn-minimal',
											className
										]}
										{...attrs}
									>
										{text}
										{icon && icon.name === 'right-arrow' && <span class="hero-icon">→</span>}
										{icon && icon.name === 'external' && <span class="hero-icon">↗</span>}
									</a>
								);
							}
						)}
					</div>
				)
			}
		</div>

		<div class="hero-visual p-4 rounded-[2.5rem] bg-gray-900/30 backdrop-blur border border-gray-700/50 shadow-2xl">
			{
				darkImage && (
					<Image
						src={darkImage}
						{...imageAttrs}
						class:list={['hero-img', { 'light:sl-hidden': Boolean(lightImage) }]}
					/>
				)
			}
			{lightImage && <Image src={lightImage} {...imageAttrs} class="hero-img dark:sl-hidden" />}
			{rawHtml && <div class="hero-html" set:html={rawHtml} />}
		</div>
	</div>
</div>

<style>
	.hero {
		padding: 6rem 1rem 6rem;
		min-height: 75vh;
		display: flex;
		align-items: center;
		overflow: hidden;
		border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-6) 50%, transparent);
	}

	.hero-inner {
		max-width: 80rem;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
		z-index: 10;
		position: relative;
	}

	@media (min-width: 64rem) {
		.hero-inner {
			grid-template-columns: 1.2fr 1fr;
			gap: 4rem;
		}
	}

	.hero-content {
		text-align: center;
	}

	@media (min-width: 64rem) {
		.hero-content {
			text-align: left;
		}
	}

	.hero-title {
		font-size: clamp(2.5rem, 5vw + 1rem, 4.5rem);
		font-weight: 800;
		line-height: 1.1;
		color: var(--sl-color-white);
		margin-bottom: 1.5rem;
		letter-spacing: -0.02em;
	}

	.hero-title :global(span) {
		/* Override starlight's inline class from index.mdx with our dynamic gradient */
		background: linear-gradient(135deg, var(--color-accent-300), var(--color-accent-600), var(--color-accent-400));
		background-size: 200% 200%;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		animation: gradient-shift 6s ease infinite;
	}

	.hero-tagline {
		font-size: clamp(1.125rem, 2vw + 0.5rem, 1.375rem);
		color: var(--sl-color-gray-2);
		margin-bottom: 2.5rem;
		line-height: 1.6;
		max-width: 40ch;
		margin-inline: auto;
		font-weight: 300;
	}

	@media (min-width: 64rem) {
		.hero-tagline {
			margin-inline: 0;
		}
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
	}

	@media (min-width: 64rem) {
		.hero-actions {
			justify-content: flex-start;
		}
	}

	.hero-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5em;
		padding: 0.875rem 1.75rem;
		border-radius: 9999px;
		font-weight: 600;
		font-size: 1.05rem;
		text-decoration: none;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		line-height: 1;
	}

	.hero-btn-primary {
		color: white;
	}

	.hero-btn-minimal {
		background: color-mix(in srgb, var(--sl-color-gray-6) 40%, transparent);
		color: var(--sl-color-white);
		backdrop-filter: blur(8px);
		border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 50%, transparent);
	}

	.hero-btn-minimal:hover {
		background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
		border-color: var(--sl-color-gray-4);
		transform: translateY(-2px);
	}

	.hero-icon {
		font-size: 1.25em;
		font-weight: 400;
		transition: transform 0.2s;
	}

	.hero-btn:hover .hero-icon {
		transform: translateX(3px);
	}
	
	.hero-btn[href^="http"]:hover .hero-icon {
		transform: translate(2px, -2px);
	}

	.hero-visual {
		display: flex;
		justify-content: center;
		position: relative;
	}
	
	/* Add a soft glow behind the image */
	.hero-visual::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		width: 80%;
		height: 80%;
		transform: translate(-50%, -50%);
		background: radial-gradient(circle, color-mix(in srgb, var(--sl-color-accent-500) 30%, transparent) 0%, transparent 70%);
		z-index: -1;
		filter: blur(40px);
		border-radius: 50%;
	}

	.hero-img,
	.hero-html {
		width: 100%;
		max-width: 32rem;
		height: auto;
		object-fit: contain;
		filter: drop-shadow(0 20px 40px rgb(0 0 0 / 0.4));
	}

	/* Animations */
	.slide-up {
		animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		opacity: 0;
	}

	@keyframes slideUp {
		0% { transform: translateY(30px); opacity: 0; }
		100% { transform: translateY(0); opacity: 1; }
	}

	.float-animation {
		animation: floatImage 8s ease-in-out infinite;
	}

	@keyframes floatImage {
		0% { transform: translateY(0px) rotate(0deg); }
		50% { transform: translateY(-15px) rotate(1deg); }
		100% { transform: translateY(0px) rotate(0deg); }
	}
</style>
