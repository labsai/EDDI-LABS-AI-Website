---
/**
 * Shared Track Record page content — used by both root and [lang] trust pages.
 * Showcases institutional validation, enterprise deployments, and community trust signals.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, type Locale } from '../../i18n';
import type { TranslationSchema } from '../../i18n';

interface Props {
	lang: Locale;
	t: TranslationSchema;
}

const { lang, t } = Astro.props;
const trust = t.pages.trust;
---

<BaseLayout title={trust.title} description={trust.description} fullWidth={true} lang={lang}>

<!-- Hero Section -->
<section class="hero-section hero-gradient hero-gradient-bg">
	<div class="hero-inner trust-hero-inner">
		<div class="hero-text trust-hero-text">
			<h1>
				{trust.heroTitle}<br/>
				<span class="text-gradient-dynamic">{trust.heroHighlight}</span>
			</h1>
			<p class="hero-tagline" set:html={trust.heroDesc} />
		</div>
	</div>
	<!-- Stats bar -->
	<div class="trust-stats-bar">
		<div class="trust-stat">
			<span class="trust-stat-value">100K+</span>
			<span class="trust-stat-label">{trust.statPulls}</span>
		</div>
		<div class="trust-stat">
			<span class="trust-stat-value">2,000+</span>
			<span class="trust-stat-label">{trust.statTests}</span>
		</div>
		<div class="trust-stat">
			<span class="trust-stat-value">12+</span>
			<span class="trust-stat-label">{trust.statProviders}</span>
		</div>
		<div class="trust-stat">
			<span class="trust-stat-value">✓</span>
			<span class="trust-stat-label">{trust.statCertified}</span>
		</div>
	</div>
</section>

<!-- Timeline Section -->
<section class="py-24 max-w-5xl mx-auto px-6">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{trust.timelineTitle}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">{trust.timelineDesc}</p>
	</div>
	<div class="trust-timeline not-content">
		{trust.timeline.map((item, i) => (
			<div class="trust-timeline-item" style={`--delay: ${i * 0.08}s`}>
				<div class="trust-timeline-year">{item.year}</div>
				<div class="trust-timeline-dot"></div>
				<div class="trust-timeline-content" set:html={item.text} />
			</div>
		))}
	</div>
</section>

<!-- Institutional Backing Section -->
<section class="py-24 max-w-7xl mx-auto px-6">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{trust.institutionsTitle}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">{trust.institutionsDesc}</p>
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
		<!-- FFG -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instFFGTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instFFGDesc} />
		</div>
		<!-- EU / ELG -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instEUTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instEUDesc} />
		</div>
		<!-- EDUBOTS -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instEdubotsTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instEdubotsDesc} />
		</div>
		<!-- weXelerate -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instWexTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instWexDesc} />
		</div>
		<!-- inits.at -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instInitsTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instInitsDesc} />
		</div>
		<!-- Red Hat -->
		<div class="trust-card group">
			<div class="trust-card-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{trust.instRedHatTitle}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={trust.instRedHatDesc} />
		</div>
	</div>

	<!-- EDUBOTS Partners (collapsible) -->
	<details class="trust-partners-details mt-8">
		<summary class="trust-partners-summary">{trust.edubotsPartnersTitle}</summary>
		<div class="trust-partners-grid not-content">
			{trust.edubotsPartners.map((partner) => (
				<div class="trust-partner-chip">
					<span class="trust-partner-name">{partner.name}</span>
					<span class="trust-partner-country">{partner.country}</span>
				</div>
			))}
		</div>
	</details>
</section>

<!-- Enterprise Deployment Section -->
<section class="py-24 max-w-7xl mx-auto px-6">
	<div class="trust-enterprise-card not-content">
		<div class="trust-enterprise-content">
			<h2 class="text-3xl md:text-4xl font-bold mb-6 text-white! border-0!">{trust.enterpriseTitle}</h2>
			<p class="text-zinc-300 text-base leading-relaxed mb-8" set:html={trust.enterpriseDesc} />
			<div class="trust-enterprise-stats">
				<div class="trust-enterprise-stat">
					<span class="trust-enterprise-stat-value">{trust.enterpriseStat1}</span>
					<span class="trust-enterprise-stat-label">{trust.enterpriseStat1Label}</span>
				</div>
				<div class="trust-enterprise-stat">
					<span class="trust-enterprise-stat-value">{trust.enterpriseStat2}</span>
					<span class="trust-enterprise-stat-label">{trust.enterpriseStat2Label}</span>
				</div>
				<div class="trust-enterprise-stat">
					<span class="trust-enterprise-stat-value">{trust.enterpriseStat3}</span>
					<span class="trust-enterprise-stat-label">{trust.enterpriseStat3Label}</span>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Developer Trust Signals Section -->
<section class="py-24 max-w-7xl mx-auto px-6">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{trust.devTrustTitle}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">{trust.devTrustDesc}</p>
	</div>

	<!-- Live Badges Row -->
	<div class="trust-badges-row not-content">
		<a href="https://www.bestpractices.dev/projects/12355" target="_blank" rel="noopener">
			<img src="https://www.bestpractices.dev/projects/12355/badge" alt="OpenSSF Best Practices" loading="lazy" />
		</a>
		<a href="https://app.codacy.com/organizations/gh/labsai/dashboard" target="_blank" rel="noopener">
			<img src="https://app.codacy.com/project/badge/Grade/2c5d183d4bd24dbaa77427cfbf5d4074" alt="Codacy Badge" loading="lazy" />
		</a>
		<a href="https://github.com/labsai/EDDI/actions/workflows/ci.yml" target="_blank" rel="noopener">
			<img src="https://github.com/labsai/EDDI/actions/workflows/ci.yml/badge.svg" alt="CI" loading="lazy" />
		</a>
		<a href="https://github.com/labsai/EDDI/actions/workflows/codeql.yml" target="_blank" rel="noopener">
			<img src="https://github.com/labsai/EDDI/actions/workflows/codeql.yml/badge.svg" alt="CodeQL" loading="lazy" />
		</a>
		<a href="https://hub.docker.com/r/labsai/eddi" target="_blank" rel="noopener">
			<img src="https://img.shields.io/docker/pulls/labsai/eddi" alt="Docker Pulls" loading="lazy" />
		</a>
	</div>

	<!-- Trust signal cards grid -->
	<div class="not-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-10">
		<div class="trust-signal-card">
			<div class="trust-signal-icon">🛡️</div>
			<h4 class="trust-signal-title">{trust.devOpenSSF}</h4>
			<p class="trust-signal-desc">{trust.devOpenSSFDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon">📊</div>
			<h4 class="trust-signal-title">{trust.devCodacy}</h4>
			<p class="trust-signal-desc">{trust.devCodacyDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon">🐳</div>
			<h4 class="trust-signal-title">{trust.devDocker}</h4>
			<p class="trust-signal-desc">{trust.devDockerDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon">✅</div>
			<h4 class="trust-signal-title">{trust.devCI}</h4>
			<p class="trust-signal-desc">{trust.devCIDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon">🔍</div>
			<h4 class="trust-signal-title">{trust.devCodeQL}</h4>
			<p class="trust-signal-desc">{trust.devCodeQLDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon">🧪</div>
			<h4 class="trust-signal-title">{trust.devTests}</h4>
			<p class="trust-signal-desc">{trust.devTestsDesc}</p>
		</div>
		<div class="trust-signal-card">
			<div class="trust-signal-icon" aria-hidden="true">⚖️</div>
			<h4 class="trust-signal-title">{trust.devApache}</h4>
			<p class="trust-signal-desc">{trust.devApacheDesc}</p>
		</div>
	</div>
</section>

<!-- CTA Section -->
<section class="py-24 max-w-5xl mx-auto px-6 text-center">
	<h2 class="text-3xl md:text-5xl font-bold mb-12 text-white! border-0! text-center">{trust.ctaTitle}</h2>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-8">
		<a href={localePath(lang, '/getting-started/')} class="trust-cta-card group" id="trust-cta-get-started">
			<h3 class="text-xl font-bold text-white mb-2">{trust.ctaGetStarted}</h3>
			<p class="text-zinc-400 text-sm">{trust.ctaGetStartedDesc}</p>
		</a>
		<a href="https://docs.labs.ai" target="_blank" rel="noopener" class="trust-cta-card group" id="trust-cta-docs">
			<h3 class="text-xl font-bold text-white mb-2">{trust.ctaDocs}</h3>
			<p class="text-zinc-400 text-sm">{trust.ctaDocsDesc}</p>
		</a>
	</div>
</section>

</BaseLayout>

<style>
/* ===== HERO ===== */
.trust-hero-inner {
	text-align: center;
	display: flex;
	justify-content: center;
}
.trust-hero-text {
	max-width: 48rem;
}

/* ===== STATS BAR ===== */
.trust-stats-bar {
	display: flex;
	justify-content: center;
	gap: 3rem;
	padding: 2rem 1.5rem 0;
	flex-wrap: wrap;
}
.trust-stat {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 0.25rem;
}
.trust-stat-value {
	font-size: 2rem;
	font-weight: 800;
	background: linear-gradient(135deg, var(--color-accent), #f59e0b);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
	line-height: 1.1;
}
.trust-stat-label {
	font-size: 0.75rem;
	color: var(--color-text-subtle);
	text-transform: uppercase;
	letter-spacing: 0.08em;
	font-weight: 600;
}

/* ===== TIMELINE ===== */
.trust-timeline {
	position: relative;
	padding-inline-start: 2rem;
}
.trust-timeline::before {
	content: '';
	position: absolute;
	inset-inline-start: 0.5rem;
	top: 0;
	bottom: 0;
	width: 2px;
	background: linear-gradient(to bottom, var(--color-accent), transparent);
}
.trust-timeline-item {
	display: grid;
	grid-template-columns: 4rem auto;
	gap: 1.5rem;
	padding-bottom: 2rem;
	position: relative;
	opacity: 0;
	animation: trust-fade-in 0.4s ease forwards;
	animation-delay: var(--delay);
}
.trust-timeline-year {
	font-size: 0.875rem;
	font-weight: 700;
	color: var(--color-accent);
	text-align: end;
	padding-top: 0.125rem;
}
.trust-timeline-dot {
	position: absolute;
	inset-inline-start: -1.5rem;
	top: 0.375rem;
	width: 0.625rem;
	height: 0.625rem;
	border-radius: 50%;
	background: var(--color-accent);
	box-shadow: 0 0 12px color-mix(in srgb, var(--color-accent) 50%, transparent);
}
.trust-timeline-content {
	font-size: 0.9375rem;
	color: var(--color-text-muted);
	line-height: 1.6;
}
.trust-timeline-content :global(strong) {
	color: var(--color-text);
	font-weight: 600;
}

@keyframes trust-fade-in {
	from { opacity: 0; transform: translateY(0.5rem); }
	to { opacity: 1; transform: translateY(0); }
}

/* ===== INSTITUTION CARDS ===== */
.trust-card {
	position: relative;
	overflow: hidden;
	display: flex;
	flex-direction: column;
	padding: 1.75rem;
	border-radius: 1.5rem;
	background: rgba(39, 39, 42, 0.4);
	backdrop-filter: blur(12px);
	border: 1px solid rgba(63, 63, 70, 0.5);
	transition: all 0.3s ease;
}
.trust-card:hover {
	border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
	transform: translateY(-0.25rem);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.5);
}
.trust-card-icon {
	margin-bottom: 1rem;
	width: 3rem;
	height: 3rem;
	border-radius: 0.75rem;
	background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 20%, transparent), color-mix(in srgb, var(--color-accent) 5%, transparent));
	border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
	display: flex;
	align-items: center;
	justify-content: center;
	color: var(--color-accent);
	box-shadow: 0 0 24px color-mix(in srgb, var(--color-accent) 20%, transparent);
	transition: all 0.4s ease;
}
.trust-card:hover .trust-card-icon {
	transform: scale(1.1);
	box-shadow: 0 0 40px color-mix(in srgb, var(--color-accent) 50%, transparent);
}

/* ===== EDUBOTS PARTNERS DETAILS ===== */
.trust-partners-details {
	max-width: 48rem;
	margin-inline: auto;
}
.trust-partners-summary {
	cursor: pointer;
	font-size: 0.875rem;
	font-weight: 600;
	color: var(--color-text-muted);
	padding: 0.75rem 1rem;
	border-radius: 0.75rem;
	background: rgba(39, 39, 42, 0.3);
	border: 1px solid rgba(63, 63, 70, 0.3);
	transition: all 0.2s;
	text-align: center;
}
.trust-partners-summary:hover {
	color: var(--color-text);
	border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
}
.trust-partners-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
	gap: 0.75rem;
	padding-top: 1rem;
}
.trust-partner-chip {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 0.625rem 1rem;
	border-radius: 0.5rem;
	background: rgba(39, 39, 42, 0.3);
	border: 1px solid rgba(63, 63, 70, 0.3);
}
.trust-partner-name {
	font-size: 0.8125rem;
	font-weight: 600;
	color: var(--color-text-muted);
}
.trust-partner-country {
	font-size: 0.6875rem;
	color: var(--color-text-subtle);
}

/* ===== ENTERPRISE CARD ===== */
.trust-enterprise-card {
	position: relative;
	overflow: hidden;
	padding: 3rem;
	border-radius: 1.5rem;
	background: linear-gradient(135deg, rgba(39, 39, 42, 0.6), rgba(39, 39, 42, 0.2));
	backdrop-filter: blur(16px);
	border: 1px solid rgba(63, 63, 70, 0.5);
}
.trust-enterprise-card::before {
	content: '';
	position: absolute;
	top: -50%;
	inset-inline-end: -20%;
	width: 60%;
	height: 200%;
	background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 8%, transparent) 0%, transparent 70%);
	pointer-events: none;
}
.trust-enterprise-content {
	position: relative;
	z-index: 1;
}
.trust-enterprise-stats {
	display: flex;
	gap: 3rem;
	flex-wrap: wrap;
}
.trust-enterprise-stat {
	display: flex;
	flex-direction: column;
	gap: 0.25rem;
}
.trust-enterprise-stat-value {
	font-size: 2.5rem;
	font-weight: 800;
	background: linear-gradient(135deg, var(--color-accent), #f59e0b);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
	line-height: 1.1;
}
.trust-enterprise-stat-label {
	font-size: 0.8125rem;
	color: var(--color-text-subtle);
	font-weight: 500;
}

/* ===== BADGES ROW ===== */
.trust-badges-row {
	display: flex;
	justify-content: center;
	gap: 0.75rem;
	flex-wrap: wrap;
}
.trust-badges-row a {
	display: inline-flex;
	transition: transform 0.2s;
}
.trust-badges-row a:hover {
	transform: scale(1.08);
}
.trust-badges-row img {
	height: 1.5rem;
}

/* ===== TRUST SIGNAL CARDS ===== */
.trust-signal-card {
	padding: 1.25rem;
	border-radius: 1rem;
	background: rgba(39, 39, 42, 0.3);
	border: 1px solid rgba(63, 63, 70, 0.3);
	transition: border-color 0.2s;
}
.trust-signal-card:hover {
	border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
}
.trust-signal-icon {
	font-size: 1.5rem;
	margin-bottom: 0.5rem;
}
.trust-signal-title {
	font-size: 0.875rem;
	font-weight: 700;
	color: var(--color-text);
	margin-bottom: 0.25rem;
}
.trust-signal-desc {
	font-size: 0.75rem;
	color: var(--color-text-subtle);
	line-height: 1.5;
}

/* ===== CTA CARDS ===== */
.trust-cta-card {
	display: block;
	padding: 2rem;
	border-radius: 1.5rem;
	background: rgba(39, 39, 42, 0.4);
	backdrop-filter: blur(12px);
	border: 1px solid rgba(63, 63, 70, 0.5);
	text-decoration: none;
	transition: all 0.3s ease;
}
.trust-cta-card:hover {
	border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
	transform: translateY(-0.25rem);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.5);
}

/* ===== LIGHT MODE ===== */
html[data-theme='light'] .trust-card,
html[data-theme='light'] .trust-signal-card,
html[data-theme='light'] .trust-cta-card,
html[data-theme='light'] .trust-enterprise-card,
html[data-theme='light'] .trust-partner-chip,
html[data-theme='light'] .trust-partners-summary {
	background: rgba(255, 255, 255, 0.7);
	border-color: rgba(228, 228, 231, 0.8);
}
html[data-theme='light'] .trust-card:hover,
html[data-theme='light'] .trust-cta-card:hover {
	background: rgba(255, 255, 255, 0.9);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.1);
}
html[data-theme='light'] .trust-timeline-content {
	color: var(--color-text-muted);
}
html[data-theme='light'] .trust-signal-title,
html[data-theme='light'] h3 {
	color: var(--color-text);
}
html[data-theme='light'] .trust-enterprise-card::before {
	background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, transparent 70%);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 48rem) {
	.trust-stats-bar {
		gap: 1.5rem;
	}
	.trust-stat-value {
		font-size: 1.5rem;
	}
	.trust-enterprise-card {
