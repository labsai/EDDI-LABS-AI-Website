---
/**
 * Shared Compliance page content — used by both root and [lang] versions.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero_compliance.webp';
import { localePath, type Locale } from '../../i18n';
import type { TranslationSchema } from '../../i18n';

interface Props {
	lang: Locale;
	t: TranslationSchema;
}

const { lang, t } = Astro.props;
const p = t.pages.compliance;

/* ── SVG icon paths (Lucide-style) for each regulation card ── */
const icons = {
	euAiAct: '<path d="M12 2a8 8 0 0 0-8 8v4a8 8 0 0 0 16 0v-4a8 8 0 0 0-8-8z"/><path d="M12 14v4"/><path d="M8 14h8"/>',
	nist:    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
	iso:     '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>',
	gdpr:    '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
	ccpa:    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m16 11 2 2 4-4"/>',
	pipeda:  '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="m9 15 2 2 4-4"/>',
	lgpd:    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
	appi:    '<path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/>',
	popia:   '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4"/><path d="M12 16h.01"/>',
	pdpa:    '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><path d="M14 2v6h6"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/>',
	pdpaMY:  '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/>',
	pipl:    '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
	hipaa:   '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>',
	soc2:    '<path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/>',
	api:     '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
	arch:    '<path d="M2 20h20"/><path d="M5 20V8.2a2 2 0 0 1 .6-1.4l5.8-5.6a2 2 0 0 1 2.8 0l5.8 5.6a2 2 0 0 1 .6 1.4V20"/><path d="M9 20v-6a3 3 0 0 1 6 0v6"/>',
};

/* ── Regulation card definitions ── */
const aiGovCards = [
	{ icon: icons.euAiAct, title: p.euAiActHeading, desc: p.euAiActPara, items: p.euAiActItems, accent: true },
	{ icon: icons.nist,    title: p.nistHeading,     desc: p.nistPara,     items: p.nistItems },
	{ icon: icons.iso,     title: p.isoHeading,      desc: p.isoPara,      items: p.isoItems },
];

const privacyCards = [
	{ icon: icons.ccpa,   title: p.ccpaHeading,   desc: p.ccpaPara,   items: p.ccpaItems },
	{ icon: icons.pipeda, title: p.pipedaHeading, desc: p.pipedaPara, items: p.pipedaItems },
	{ icon: icons.lgpd,   title: p.lgpdHeading,   desc: p.lgpdPara,   items: p.lgpdItems },
	{ icon: icons.appi,   title: p.appiHeading,   desc: p.appiPara,   items: p.appiItems },
	{ icon: icons.popia,  title: p.popiaHeading,  desc: p.popiaPara,  items: p.popiaItems },
	{ icon: icons.pdpa,   title: p.pdpaHeading,   desc: p.pdpaPara,   items: p.pdpaItems },
	{ icon: icons.pdpaMY, title: p.pdpaMYHeading, desc: p.pdpaMYPara, items: p.pdpaMYItems },
	{ icon: icons.pipl,   title: p.piplHeading,   desc: p.piplPara,   items: p.piplItems },
];

const industryCards = [
	{ icon: icons.hipaa, title: p.hipaaHeading, desc: p.hipaaPara, items: p.hipaaItems },
	{ icon: icons.soc2,  title: p.soc2Heading,  desc: p.soc2Para,  items: p.soc2Items },
];
---
<BaseLayout title={p.title} description={p.description} fullWidth={true} lang={lang}>

<!-- ═══ HERO ═══ -->
<section class="cp-hero hero-gradient hero-gradient-bg"><div class="cp-hero-inner">
	<div class="cp-hero-text">
		<h1>{p.title}</h1>
		<p class="cp-hero-tagline">{p.description}</p>
		<div class="cp-hero-actions">
			<a href={localePath(lang, '/getting-started/')} class="btn-cta-primary">{t.common.getStartedCta}</a>
			<a href="https://github.com/labsai/EDDI" class="btn-cta-outline" target="_blank" rel="noopener">{t.common.viewOnGithub}</a>
		</div>
	</div>
	<div class="cp-hero-image premium-image-wrapper">
		<Image src={heroImage} alt={p.title} width={1024} height={1024} loading="eager" decoding="async" />
	</div>
</div></section>

<!-- ═══ COMPLIANCE BY ARCHITECTURE — intro ═══ -->
<section class="py-20 max-w-7xl mx-auto px-6">
	<div class="not-content relative overflow-hidden p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 transition-all duration-300 hover:border-accent-500/50 hover:shadow-xl group">
		<div class="absolute top-2 end-2 opacity-[0.04] group-hover:opacity-[0.08] transition-opacity duration-500 pointer-events-none">
			<svg class="w-28 h-28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" set:html={icons.arch} />
		</div>
		<div class="flex items-start gap-6">
			<div class="w-14 h-14 shrink-0 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.arch} />
			</div>
			<div>
				<h2 class="text-2xl font-bold text-white! mb-3 border-0!">{p.heading1}</h2>
				<p class="text-zinc-400 text-sm leading-relaxed m-0" set:html={p.para1} />
			</div>
		</div>
	</div>
</section>

<!-- ═══ AI GOVERNANCE FRAMEWORKS ═══ -->
<section class="py-24 max-w-7xl mx-auto px-6 relative border-t border-zinc-800/60">
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-accent-500/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{p.aiGovHeading}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed" set:html={p.aiGovIntro} />
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
		{aiGovCards.map((card) => (
			<div class={`relative overflow-hidden flex flex-col h-full p-8 rounded-3xl ${card.accent ? 'bg-linear-to-tr from-accent-900/10 to-zinc-900/60' : 'bg-zinc-900/40'} backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group`}>
				<div class="absolute top-2 end-2 opacity-[0.06] group-hover:opacity-[0.10] transition-opacity duration-500 pointer-events-none">
					<svg class="w-24 h-24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<div class="mb-6 w-14 h-14 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
					<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<h3 class="text-xl font-bold text-white mb-3">{card.title}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed mb-4" set:html={card.desc} />
				<ul class="cp-check-list grow">{card.items.map((item) => <li set:html={item} />)}</ul>
			</div>
		))}
	</div>
</section>

<!-- ═══ DATA PRIVACY REGULATIONS ═══ -->
<section class="py-24 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{p.privacyHeading}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed" set:html={p.privacyIntro} />
	</div>
	<!-- GDPR — featured full-width card -->
	<div class="not-content relative overflow-hidden p-8 rounded-3xl bg-linear-to-tr from-accent-900/10 to-zinc-900/60 backdrop-blur border border-accent-500/30 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-1 shadow-xl group mb-10">
		<div class="absolute top-2 end-2 opacity-[0.06] group-hover:opacity-[0.10] transition-opacity duration-500 pointer-events-none">
			<svg class="w-32 h-32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" set:html={icons.gdpr} />
		</div>
		<div class="flex items-start gap-6 mb-6">
			<div class="w-14 h-14 shrink-0 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.gdpr} />
			</div>
			<div>
				<h3 class="text-xl font-bold text-white mb-2">{p.gdprHeading}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed m-0" set:html={p.gdprPara} />
			</div>
		</div>
		<div class="cp-gdpr-cols"><ul class="cp-check-list">{p.gdprItems.map((item) => <li set:html={item} />)}</ul></div>
	</div>
	<!-- Privacy regulation grid -->
	<div class="not-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
		{privacyCards.map((card) => (
			<div class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group">
				<div class="absolute top-2 end-2 opacity-[0.06] group-hover:opacity-[0.10] transition-opacity duration-500 pointer-events-none">
					<svg class="w-24 h-24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<div class="mb-6 w-14 h-14 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
					<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<h3 class="text-xl font-bold text-white mb-3">{card.title}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed mb-4" set:html={card.desc} />
				<ul class="cp-check-list grow">{card.items.map((item) => <li set:html={item} />)}</ul>
			</div>
		))}
	</div>
	<!-- Additional jurisdictions -->
	<div class="mt-12 text-center">
		<h3 class="text-xl font-bold text-white mb-6">{p.otherRegionsHeading}</h3>
		<div class="flex flex-wrap gap-3 justify-center">
			{p.otherRegionsItems.map((item) => (
				<span class="inline-flex items-center px-4 py-2 rounded-full text-sm bg-zinc-900/40 backdrop-blur border border-zinc-700/50 text-zinc-300 hover:border-accent-500/50 hover:text-accent-400 transition-all duration-300" set:html={item} />
			))}
		</div>
	</div>
</section>

<!-- ═══ INDUSTRY-SPECIFIC COMPLIANCE ═══ -->
<section class="py-24 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16"><h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{p.industryHeading}</h2></div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
		{industryCards.map((card) => (
			<div class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group">
				<div class="absolute top-2 end-2 opacity-[0.06] group-hover:opacity-[0.10] transition-opacity duration-500 pointer-events-none">
					<svg class="w-24 h-24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<div class="mb-6 w-14 h-14 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
					<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
				</div>
				<h3 class="text-xl font-bold text-white mb-3">{card.title}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed mb-4" set:html={card.desc} />
				<ul class="cp-check-list grow">{card.items.map((item) => <li set:html={item} />)}</ul>
			</div>
		))}
	</div>
</section>

<!-- ═══ ONE API FOR GLOBAL COMPLIANCE ═══ -->
<section class="py-24 max-w-7xl mx-auto px-6 relative border-t border-zinc-800/60">
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3/4 h-3/4 bg-accent-500/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{p.apiHeading}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed" set:html={p.apiPara} />
	</div>
	<div class="not-content grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-stretch">
		{p.apiItems.map((item, i) => (
			<div class={`relative overflow-hidden flex flex-col items-center text-center p-6 rounded-2xl ${i < 3 ? 'bg-linear-to-tr from-accent-900/10 to-zinc-900/60' : 'bg-zinc-900/40'} backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg group`}>
				<div class="w-10 h-10 mb-4 rounded-xl bg-accent-500/10 text-accent-400 flex items-center justify-center border border-accent-500/20 group-hover:bg-accent-500/20 group-hover:scale-110 transition-all duration-300">
					<svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.api} />
				</div>
				<div class="cp-api-text" set:html={item} />
			</div>
		))}
	</div>
</section>

<!-- ═══ CLOSING CTA ═══ -->
<section class="py-24 max-w-5xl mx-auto px-6 border-t border-zinc-800/60 text-center">
	<h2 class="text-3xl md:text-4xl font-bold mb-4 text-white! border-0!">{p.heading3}</h2>
	<p class="text-xl text-zinc-400 max-w-2xl mx-auto font-light leading-relaxed mb-8" set:html={p.para2} />
	<div class="cp-closing-actions">
		<a href={localePath(lang, '/getting-started/')} class="btn-cta-primary">{t.common.getStartedCta}</a>
		<a href="https://github.com/labsai/EDDI" class="btn-cta-outline" target="_blank" rel="noopener">{t.common.viewOnGithub}</a>
	</div>
</section>

</BaseLayout>

<style>
	.cp-hero { padding: calc(var(--total-header-height, 6rem) + 3rem) 1.5rem 3rem; }
	.cp-hero-inner { max-width: 72rem; margin: 0 auto; display: flex; align-items: center; gap: 3rem; }
	.cp-hero-text { flex: 1; }
	.cp-hero-text h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; margin: 0 0 1rem; color: var(--color-text); }
	.cp-hero-tagline { font-size: 1.125rem; line-height: 1.65; margin: 0 0 2rem; max-width: 36rem; color: var(--color-text-muted); }
	.cp-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
	.cp-hero-image { flex-shrink: 0; }
	.cp-hero-image img { display: block; width: 100%; height: auto; max-width: 28rem; object-fit: contain; }
	@media (max-width: 64rem) { .cp-hero-inner { gap: 2rem; } .cp-hero-image img { max-width: 20rem; } }
	@media (max-width: 50rem) { .cp-hero-inner { flex-direction: column; text-align: center; } .cp-hero-tagline { max-width: none; } .cp-hero-actions { justify-content: center; gap: 0.75rem; } .cp-hero-image { max-width: 20rem; } }
	@media (max-width: 30rem) { .cp-hero-actions { justify-content: center; margin: 0 auto; } .cp-hero-image { max-width: 16rem; } }
	.cp-check-list { list-style: none; padding: 0; margin: 0; }
	.cp-check-list li { position: relative; padding-inline-start: 1.5rem; margin-bottom: 0.5rem; font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.6; }
	.cp-check-list li::before { content: '✓'; position: absolute; inset-inline-start: 0; color: var(--color-accent); font-weight: 700; font-size: 0.8125rem; }
	.cp-check-list :global(strong) { color: var(--color-text); }
	.cp-check-list :global(code) { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.25rem; padding: 0.1rem 0.35rem; font-size: 0.75rem; }
	.cp-gdpr-cols { column-count: 2; column-gap: 2rem; }
	@media (max-width: 50rem) { .cp-gdpr-cols { column-count: 1; } }
	.cp-api-text { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.5; }
	.cp-api-text :global(strong) { color: var(--color-text); display: block; margin-bottom: 0.25rem; }
	.cp-api-text :global(code) { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.25rem; padding: 0.1rem 0.35rem; font-size: 0.7rem; }
	.cp-closing-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
	@media (max-width: 30rem) { .cp-closing-actions { justify-content: center; margin: 0 auto; } }
</style>
