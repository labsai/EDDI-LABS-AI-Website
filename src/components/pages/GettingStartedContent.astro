---
/**
 * Shared Getting Started content — used by both root and [lang] versions.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import managerImage from '../../assets/hero_manager.webp';
import heroImage from '../../assets/hero_getting_started.png';
import { localePath, type Locale } from '../../i18n';
import type { TranslationSchema } from '../../i18n';

interface Props {
	lang: Locale;
	t: TranslationSchema;
}

const { lang, t } = Astro.props;
---

<BaseLayout title={t.gettingStarted.title} description={t.gettingStarted.description} fullWidth={true} lang={lang}>

<section class="gs-hero hero-gradient-bg">
	<div class="gs-hero-inner">
		<div class="gs-hero-text">
			<h1>{t.gettingStarted.heroTitle}</h1>
			<p class="gs-subtitle">{t.gettingStarted.heroSubtitle}</p>
		</div>
		<div class="gs-hero-image premium-image-wrapper">
			<Image src={heroImage} alt={t.gettingStarted.heroTitle} width={1024} height={1024} loading="eager" decoding="async" />
		</div>
	</div>
</section>

<article class="gs-content">
	<section class="gs-section">
		<h2>{t.gettingStarted.prerequisitesTitle}</h2>
		<ul>
			<li set:html={t.gettingStarted.prereq1} />
			<li>{t.gettingStarted.prereq2}</li>
		</ul>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.step1Title}</h2>
		<p set:html={t.gettingStarted.step1Desc} />

		<div class="gs-tabs" id="install-tabs">
			<div class="gs-tab-bar" role="tablist">
				<button class="gs-tab active" role="tab" aria-selected="true" aria-controls="panel-installer" id="tab-installer">{t.gettingStarted.step1TabInstaller}</button>
				<button class="gs-tab" role="tab" aria-selected="false" aria-controls="panel-compose" id="tab-compose">{t.gettingStarted.step1TabCompose}</button>
			</div>
			<div class="gs-tab-panel active" role="tabpanel" id="panel-installer" aria-labelledby="tab-installer">
				<p class="gs-os-label">Linux / macOS / WSL2:</p>
				<pre><code>curl -fsSL https://raw.githubusercontent.com/labsai/EDDI/main/install.sh | bash</code></pre>
				<p class="gs-os-label">Windows (PowerShell):</p>
				<pre><code>iwr -useb https://raw.githubusercontent.com/labsai/EDDI/main/install.ps1 | iex</code></pre>
			</div>
			<div class="gs-tab-panel" role="tabpanel" id="panel-compose" aria-labelledby="tab-compose">
				<p set:html={t.gettingStarted.step1ComposeDesc} />
				<pre><code>docker compose up</code></pre>
			</div>
		</div>

		<p set:html={t.gettingStarted.step1After} />
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.step2Title}</h2>
		<p set:html={t.gettingStarted.step2Desc} />
		<pre><code>{`{
  "mcpServers": {
    "eddi": {
      "url": "http://localhost:7070/mcp"
    }
  }
}`}</code></pre>
		<p>{t.gettingStarted.step2After}</p>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.step3Title}</h2>
		<p set:html={t.gettingStarted.step3VaultIntro} />
		<div class="gs-tabs" id="vault-tabs">
			<div class="gs-tab-bar" role="tablist">
				<button class="gs-tab active" role="tab" aria-selected="true" aria-controls="panel-vault-rest" id="tab-vault-rest">REST API</button>
				<button class="gs-tab" role="tab" aria-selected="false" aria-controls="panel-vault-ui" id="tab-vault-ui">Manager UI</button>
			</div>
			<div class="gs-tab-panel active" role="tabpanel" id="panel-vault-rest" aria-labelledby="tab-vault-rest">
				<pre><code>{`curl -X PUT http://localhost:7070/secretstore/secrets/default/my-anthropic-key \\
  -H "Content-Type: application/json" \\
  -d '{"value": "sk-ant-your-actual-key", "description": "Anthropic API key"}'`}</code></pre>
			</div>
			<div class="gs-tab-panel" role="tabpanel" id="panel-vault-ui" aria-labelledby="tab-vault-ui">
				<p set:html={t.gettingStarted.step3VaultUiDesc} />
			</div>
		</div>
		<p class="gs-tip" set:html={t.gettingStarted.step3VaultTip} />
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.step4Title}</h2>
		<p set:html={t.gettingStarted.step4Desc} />
		<div class="gs-tabs" id="agent-tabs">
			<div class="gs-tab-bar" role="tablist">
				<button class="gs-tab active" role="tab" aria-selected="true" aria-controls="panel-agent-mcp" id="tab-agent-mcp">MCP</button>
				<button class="gs-tab" role="tab" aria-selected="false" aria-controls="panel-agent-rest" id="tab-agent-rest">REST API</button>
			</div>
			<div class="gs-tab-panel active" role="tabpanel" id="panel-agent-mcp" aria-labelledby="tab-agent-mcp">
				<pre><code>{`setup_agent(
  agentName: "My first agent",
  systemPrompt: "You are a helpful assistant that answers questions clearly.",
  provider: "anthropic",
  model: "claude-sonnet-4-6",
  apiKey: "\${eddivault:my-anthropic-key}"
)`}</code></pre>
			</div>
			<div class="gs-tab-panel" role="tabpanel" id="panel-agent-rest" aria-labelledby="tab-agent-rest">
				<pre><code>{`curl -X POST http://localhost:7070/administration/agents/setup \\
  -H "Content-Type: application/json" \\
  -d '{
    "agentName": "My first agent",
    "systemPrompt": "You are a helpful assistant that answers questions clearly.",
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "apiKey": "\${eddivault:my-anthropic-key}"
  }'`}</code></pre>
			</div>
		</div>
		<p>{t.gettingStarted.step4After}</p>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.step5Title}</h2>
		<div class="gs-tabs" id="chat-tabs">
			<div class="gs-tab-bar" role="tablist">
				<button class="gs-tab active" role="tab" aria-selected="true" aria-controls="panel-chat-mcp" id="tab-chat-mcp">MCP</button>
				<button class="gs-tab" role="tab" aria-selected="false" aria-controls="panel-chat-rest" id="tab-chat-rest">REST API</button>
			</div>
			<div class="gs-tab-panel active" role="tabpanel" id="panel-chat-mcp" aria-labelledby="tab-chat-mcp">
				<pre><code>{`chat_with_agent(agentId: "<your-agent-id>", message: "Hello! What can you do?")`}</code></pre>
			</div>
			<div class="gs-tab-panel" role="tabpanel" id="panel-chat-rest" aria-labelledby="tab-chat-rest">
				<pre><code>{`# Start a conversation and send a message
curl -X POST http://localhost:7070/agents/<your-agent-id>/start \\
  -H "Content-Type: application/json" \\
  -d '{"input": "Hello! What can you do?"}'`}</code></pre>
			</div>
		</div>
	</section>
	<section class="gs-section border-b-0 pb-0">
		<h2>{t.gettingStarted.step6Title}</h2>
		<p set:html={t.gettingStarted.step6Desc} />
		<div class="mt-8 mb-8 premium-image-wrapper mx-auto max-w-4xl shadow-2xl">
			<Image src={managerImage} alt={t.gettingStarted.managerImageAlt} width={1024} height={1024} loading="lazy" decoding="async" class="w-full h-auto block rounded-[1.25rem]" />
		</div>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.installerOptionsTitle}</h2>
		<p>{t.gettingStarted.installerOptionsDesc}</p>
		<ul>{t.gettingStarted.installerFlags.map((flag) => <li set:html={flag} />)}</ul>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.updateTitle}</h2>
		<p set:html={t.gettingStarted.updateDesc} />
		<pre><code>eddi update</code></pre>
		<p set:html={t.gettingStarted.updateFallback} />
		<pre><code>{`cd ~/.eddi
docker compose --env-file .env -f docker-compose.yml pull
docker compose --env-file .env -f docker-compose.yml up -d`}</code></pre>
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.k8sTitle}</h2>
		<p>{t.gettingStarted.k8sDesc}</p>
		<pre><code>kubectl apply -f https://raw.githubusercontent.com/labsai/EDDI/main/k8s/quickstart.yaml</code></pre>
		<p set:html={t.gettingStarted.k8sOptions} />
	</section>
	<section class="gs-section">
		<h2>{t.gettingStarted.sdkTitle}</h2>
		<p set:html={t.gettingStarted.sdkDesc} />
		<pre><code>{`<dependency>
    <groupId>io.quarkiverse.eddi</groupId>
    <artifactId>quarkus-eddi</artifactId>
    <version>1.0.0-SNAPSHOT</version>
</dependency>`}</code></pre>
	</section>
	<section class="gs-next-steps">
		<h2>{t.gettingStarted.whatsNextTitle}</h2>
		<div class="gs-cards">
			<a href={localePath(lang, '/features/overview/')} class="gs-card"><strong>{t.gettingStarted.nextAllFeatures}</strong><span>{t.gettingStarted.nextAllFeaturesDesc}</span></a>
			<a href={localePath(lang, '/features/mcp-server/')} class="gs-card"><strong>{t.gettingStarted.nextMcpServer}</strong><span>{t.gettingStarted.nextMcpServerDesc}</span></a>
			<a href="https://docs.labs.ai" target="_blank" rel="noopener" class="gs-card"><strong>{t.gettingStarted.nextDocs}</strong><span>{t.gettingStarted.nextDocsDesc}</span></a>
			<a href={localePath(lang, '/enterprise/why-eddi/')} class="gs-card"><strong>{t.gettingStarted.nextWhyEddi}</strong><span>{t.gettingStarted.nextWhyEddiDesc}</span></a>
		</div>
	</section>
</article>

</BaseLayout>

<style>
	.gs-hero { padding: calc(var(--total-header-height, 6rem) + 3rem) 1.5rem 3rem; }
	.gs-hero-inner { max-width: 72rem; margin: 0 auto; display: flex; align-items: center; gap: 3rem; }
	.gs-hero-text { flex: 1; }
	.gs-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; margin: 0 0 1rem; color: var(--color-text); line-height: 1.15; }
	.gs-subtitle { font-size: 1.125rem; color: var(--color-text-muted); margin: 0; max-width: 36rem; line-height: 1.65; }
	.gs-hero-image { flex-shrink: 0; border-radius: 1rem; overflow: hidden; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35); }
	html[data-theme='light'] .gs-hero-image { box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1); border: 1px solid rgba(0, 0, 0, 0.08); }
	.gs-hero-image img { display: block; width: 100%; height: auto; max-width: 28rem; object-fit: contain; }
	@media (max-width: 64rem) {
		.gs-hero-inner { gap: 2rem; }
		.gs-hero-image img { max-width: 20rem; }
	}
	@media (max-width: 50rem) {
		.gs-hero-inner { flex-direction: column; text-align: center; }
		.gs-subtitle { max-width: none; }
		.gs-hero-image { max-width: 20rem; }
	}
	@media (max-width: 30rem) {
		.gs-hero-image { max-width: 16rem; }
	}
	.gs-content { max-width: 48rem; margin: 0 auto; padding: 3rem 1.5rem 6rem; line-height: 1.8; color: var(--color-text-muted); }
	.gs-content h2 { font-size: 1.5rem; font-weight: 700; color: var(--color-text); margin: 0 0 1rem; }
	.gs-content p { margin: 0 0 1rem; }
	.gs-content ul { padding-inline-start: 1.25rem; margin: 0 0 1rem; }
	.gs-content pre { border-radius: 0.75rem; padding: 1rem 1.25rem; overflow-x: auto; font-size: 0.875rem; margin: 0 0 1rem; }
	html[data-theme='dark'] .gs-content pre { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); }
	html[data-theme='light'] .gs-content pre { background: #f5f6f8; border: 1px solid rgba(0, 0, 0, 0.08); }
	.gs-section { margin-bottom: 3rem; padding-bottom: 3rem; border-bottom: 1px solid var(--color-border); }
	.gs-next-steps { margin-top: 2rem; }
	.gs-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
	.gs-card { display: block; padding: 1.25rem; border-radius: 0.75rem; text-decoration: none; transition: all 0.3s ease; }
	html[data-theme='dark'] .gs-card { background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); }
	html[data-theme='light'] .gs-card { background: #f5f6f8; border: 1px solid rgba(0, 0, 0, 0.08); }
	.gs-card:hover { transform: translateY(-2px); border-color: var(--color-accent); }
	.gs-card strong { display: block; color: var(--color-text); margin-bottom: 0.25rem; }
	.gs-card span { font-size: 0.8125rem; color: var(--color-text-subtle); }
	@media (max-width: 40rem) { .gs-cards { grid-template-columns: 1fr; } }
	/* Tabs */
	.gs-tabs { margin: 0 0 1rem; }
	.gs-tab-bar { display: flex; gap: 0; border-bottom: 1px solid var(--color-border); margin-bottom: 1.25rem; }
	.gs-tab { background: none; border: none; padding: 0.625rem 1.25rem; font-size: 0.875rem; font-weight: 600; color: var(--color-text-muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s ease; font-family: inherit; }
	.gs-tab:hover { color: var(--color-text); }
	.gs-tab.active { color: var(--color-accent); border-bottom-color: var(--color-accent); }
	.gs-tab-panel { display: none; }
	.gs-tab-panel.active { display: block; }
	.gs-os-label { font-size: 0.8125rem; font-weight: 600; color: var(--color-text); margin: 0 0 0.375rem; }
	.gs-os-label + pre { margin-bottom: 1rem; }
	.gs-tip { font-size: 0.8125rem; line-height: 1.6; padding: 0.75rem 1rem; border-radius: 0.5rem; margin: 0 0 1rem; border-inline-start: 3px solid var(--color-accent); }
	html[data-theme='dark'] .gs-tip { background: rgba(255, 255, 255, 0.03); color: var(--color-text-muted); }
	html[data-theme='light'] .gs-tip { background: #f5f6f8; color: var(--color-text-muted); }
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll('.gs-tabs').forEach(tabContainer => {
			const tabBar = tabContainer.querySelector('.gs-tab-bar');
			if (!tabBar) return;
			tabBar.addEventListener('click', (e) => {
				const tab = (e.target as HTMLElement).closest('.gs-tab');
				if (!tab) return;
				const tabs = tabBar.querySelectorAll('.gs-tab');
				const panels = tabContainer.querySelectorAll('.gs-tab-panel');
				tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
				panels.forEach(p => p.classList.remove('active'));
				tab.classList.add('active');
				tab.setAttribute('aria-selected', 'true');
				const panelId = tab.getAttribute('aria-controls');
				if (panelId) document.getElementById(panelId)?.classList.add('active');
			});
		});
	});
</script>
