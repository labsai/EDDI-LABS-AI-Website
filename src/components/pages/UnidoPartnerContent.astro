---
/**
 * Shared UNIDO Trusted Partner page content — used by both root and [lang] routes.
 * Showcases the UNIDO/AIM Global recognition, certificate, and what it means.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import certImage from '../../assets/unido_certificate.png';
import { localePath, type Locale } from '../../i18n';
import type { TranslationSchema } from '../../i18n';

interface Props {
	lang: Locale;
	t: TranslationSchema;
}

const { lang, t } = Astro.props;
const unido = t.pages.unido;
---

<BaseLayout title={unido.title} description={unido.description} fullWidth={true} lang={lang}>

<!-- Hero Section -->
<section class="unido-hero hero-gradient hero-gradient-bg">
	<div class="unido-hero-inner">
		<div class="unido-hero-badge">{unido.heroBadge}</div>
		<h1 class="unido-hero-title">
			{unido.heroTitle}<br/>
			<span class="text-gradient-dynamic">{unido.heroHighlight}</span>
		</h1>
		<p class="unido-hero-desc" set:html={unido.heroDesc} />
	</div>
</section>

<!-- Certificate Section -->
<section class="py-20 max-w-5xl mx-auto px-6">
	<div class="text-center mb-10">
		<h2 class="text-3xl font-bold text-white! border-0! text-center">{unido.certTitle}</h2>
	</div>
	<div class="unido-cert-wrapper not-content">
		<Image
			src={certImage}
			alt={unido.certAlt}
			width={1200}
			loading="eager"
			decoding="async"
			class="unido-cert-img"
		/>
	</div>
	<p class="text-center text-sm text-zinc-400 mt-6">{unido.certIssuedBy}</p>
</section>

<!-- Solution Section -->
<section class="py-20 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-12">
		<h2 class="text-3xl md:text-4xl font-bold mb-4 text-white! border-0! text-center">{unido.solutionTitle}</h2>
		<p class="text-xl text-accent-400 font-semibold mb-6">{unido.solutionSubtitle}</p>
		<p class="text-lg text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">{unido.solutionDesc}</p>
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
		{[
			{ title: unido.solCard1Title, desc: unido.solCard1Desc, icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
			{ title: unido.solCard2Title, desc: unido.solCard2Desc, icon: '<path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/>' },
			{ title: unido.solCard3Title, desc: unido.solCard3Desc, icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/>' },
			{ title: unido.solCard4Title, desc: unido.solCard4Desc, icon: '<path d="M9 17H7A5 5 0 0 1 7 7h2"/><path d="M15 7h2a5 5 0 1 1 0 10h-2"/><line x1="8" y1="12" x2="16" y2="12"/>' },
		].map((item) => (
			<div class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-1 shadow-xl group">
				<div class="mb-5 w-12 h-12 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 group-hover:scale-110 transition-all duration-300">
					<svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
				</div>
				<h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed grow">{item.desc}</p>
			</div>
		))}
	</div>
</section>

<!-- What This Means -->
<section class="py-20 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{unido.whatTitle}</h2>
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
		{[
			{ title: unido.whatCard1Title, desc: unido.whatCard1Desc, icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>' },
			{ title: unido.whatCard2Title, desc: unido.whatCard2Desc, icon: '<path d="M9 17H7A5 5 0 0 1 7 7h2"/><path d="M15 7h2a5 5 0 1 1 0 10h-2"/><line x1="8" y1="12" x2="16" y2="12"/>' },
			{ title: unido.whatCard3Title, desc: unido.whatCard3Desc, icon: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2l-4 5-4-5"/>' },
			{ title: unido.whatCard4Title, desc: unido.whatCard4Desc, icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>' },
		].map((item) => (
			<div class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group">
				<div class="mb-6 w-14 h-14 rounded-2xl bg-linear-to-br from-accent-500/20 to-accent-900/40 border border-accent-500/30 flex items-center justify-center text-accent-400 shadow-[0_0_30px_color-mix(in_srgb,var(--color-accent)_20%,transparent)] group-hover:scale-110 group-hover:shadow-[0_0_40px_color-mix(in_srgb,var(--color-accent)_50%,transparent)] transition-all duration-500">
					<svg class="w-7 h-7" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
				</div>
				<h3 class="text-xl font-bold text-white mb-3">{item.title}</h3>
				<p class="text-zinc-400 text-sm leading-relaxed grow">{item.desc}</p>
			</div>
		))}
	</div>
</section>

<!-- The Organizations -->
<section class="py-20 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{unido.orgsTitle}</h2>
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
		<!-- UNIDO -->
		<a href="https://www.unido.org/" target="_blank" rel="noopener" class="unido-org-card group no-underline!">
			<div class="unido-org-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.org1Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed mb-3" set:html={unido.org1Desc} />
			<span class="text-accent-400 text-sm font-semibold">{unido.org1Link}</span>
		</a>
		<!-- AIM Global -->
		<a href="https://aim-global.org/" target="_blank" rel="noopener" class="unido-org-card group no-underline!">
			<div class="unido-org-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17H7A5 5 0 0 1 7 7h2"/><path d="M15 7h2a5 5 0 1 1 0 10h-2"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.org2Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed mb-3" set:html={unido.org2Desc} />
			<span class="text-accent-400 text-sm font-semibold">{unido.org2Link}</span>
		</a>
		<!-- Shanghai AI Research Institute -->
		<div class="unido-org-card group">
			<div class="unido-org-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.org3Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed" set:html={unido.org3Desc} />
		</div>
		<!-- WAIC 2026 -->
		<a href="https://www.worldaic.com.cn/" target="_blank" rel="noopener" class="unido-org-card group no-underline!">
			<div class="unido-org-icon">
				<svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 2l-4 5-4-5"/></svg>
			</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.org4Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed mb-3" set:html={unido.org4Desc} />
			<span class="text-accent-400 text-sm font-semibold">{unido.org4Link}</span>
		</a>
	</div>
</section>

<!-- SDG Alignment -->
<section class="py-20 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{unido.sdgTitle}</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">{unido.sdgDesc}</p>
	</div>
	<div class="not-content grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
		<div class="sdg-card sdg-9 group">
			<div class="sdg-number">9</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.sdg9Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed">{unido.sdg9Desc}</p>
		</div>
		<div class="sdg-card sdg-8 group">
			<div class="sdg-number">8</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.sdg8Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed">{unido.sdg8Desc}</p>
		</div>
		<div class="sdg-card sdg-10 group">
			<div class="sdg-number">10</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.sdg10Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed">{unido.sdg10Desc}</p>
		</div>
		<div class="sdg-card sdg-12 group">
			<div class="sdg-number">12</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.sdg12Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed">{unido.sdg12Desc}</p>
		</div>
		<div class="sdg-card sdg-17 group md:col-span-2">
			<div class="sdg-number">17</div>
			<h3 class="text-lg font-bold text-white mb-2">{unido.sdg17Title}</h3>
			<p class="text-zinc-400 text-sm leading-relaxed">{unido.sdg17Desc}</p>
		</div>
	</div>
</section>

<!-- CTA Section -->
<section class="py-24 max-w-5xl mx-auto px-6 text-center border-t border-zinc-800/60">
	<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">{unido.ctaTitle}</h2>
	<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed mb-12">{unido.ctaDesc}</p>
	<div class="not-content flex flex-col sm:flex-row gap-4 justify-center">
		<a href={localePath(lang, '/getting-started/')} class="btn-cta-primary">{unido.ctaGetStarted}</a>
		<a href={localePath(lang, '/enterprise/trust/')} class="btn-cta-outline">{unido.ctaTrackRecord}</a>
	</div>
</section>

</BaseLayout>

<style>
/* ===== HERO ===== */
.unido-hero {
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	text-align: center;
	padding: calc(var(--total-header-height, 6rem) + 4rem) 1.5rem 4rem;
	min-height: 55vh;
}
.unido-hero-inner {
	max-width: 48rem;
}
.unido-hero-badge {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.375rem 1rem;
	border-radius: 9999px;
	font-size: 0.8125rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.05em;
	background: color-mix(in srgb, var(--color-accent) 12%, var(--color-bg, #09090b));
	border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
	color: var(--color-accent);
	margin-bottom: 1.5rem;
	box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent) 15%, transparent);
}
.unido-hero-title {
	font-size: clamp(2.5rem, 6vw, 4.5rem);
	font-weight: 800;
	line-height: 1.08;
	letter-spacing: -0.03em;
	margin-bottom: 1.5rem;
	color: var(--color-text);
}
.unido-hero-desc {
	font-size: 1.125rem;
	line-height: 1.7;
	color: var(--color-text-muted);
	max-width: 38rem;
	margin: 0 auto;
}
.unido-hero-desc :global(strong) {
	color: var(--color-text);
}

/* ===== CERTIFICATE ===== */
.unido-cert-wrapper {
	max-width: 52rem;
	margin: 0 auto;
	border-radius: 1.25rem;
	overflow: hidden;
	border: 1px solid rgba(63, 63, 70, 0.5);
	box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3), 0 0 40px color-mix(in srgb, var(--color-accent) 8%, transparent);
	transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.unido-cert-wrapper:hover {
	transform: translateY(-4px);
	box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4), 0 0 60px color-mix(in srgb, var(--color-accent) 12%, transparent);
}
.unido-cert-img {
	width: 100%;
	height: auto;
	display: block;
}
html[data-theme='light'] .unido-cert-wrapper {
	border-color: rgba(228, 228, 231, 0.8);
	box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
}
html[data-theme='light'] .unido-cert-wrapper:hover {
	box-shadow: 0 30px 80px rgba(0, 0, 0, 0.12);
}

/* ===== ORGANIZATION CARDS ===== */
.unido-org-card {
	position: relative;
	overflow: hidden;
	display: flex;
	flex-direction: column;
	padding: 1.75rem;
	border-radius: 1.5rem;
	background: rgba(39, 39, 42, 0.4);
	backdrop-filter: blur(12px);
	border: 1px solid rgba(63, 63, 70, 0.5);
	transition: all 0.3s ease;
	text-decoration: none;
}
.unido-org-card:hover {
	border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
	transform: translateY(-0.25rem);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.5);
}
.unido-org-icon {
	margin-bottom: 1rem;
	width: 3rem;
	height: 3rem;
	border-radius: 0.75rem;
	background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 20%, transparent), color-mix(in srgb, var(--color-accent) 5%, transparent));
	border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
	display: flex;
	align-items: center;
	justify-content: center;
	color: var(--color-accent);
	box-shadow: 0 0 24px color-mix(in srgb, var(--color-accent) 20%, transparent);
	transition: all 0.4s ease;
}
.unido-org-card:hover .unido-org-icon {
	transform: scale(1.1);
	box-shadow: 0 0 40px color-mix(in srgb, var(--color-accent) 50%, transparent);
}

/* Light mode */
html[data-theme='light'] .unido-org-card {
	background: rgba(255, 255, 255, 0.7);
	border-color: rgba(228, 228, 231, 0.8);
}
html[data-theme='light'] .unido-org-card:hover {
	background: rgba(255, 255, 255, 0.9);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.1);
}

/* ===== SDG CARDS ===== */
.sdg-card {
	position: relative;
	overflow: hidden;
	display: flex;
	flex-direction: column;
	padding: 1.75rem;
	border-radius: 1.5rem;
	background: rgba(39, 39, 42, 0.4);
	backdrop-filter: blur(12px);
	border: 1px solid rgba(63, 63, 70, 0.5);
	transition: all 0.3s ease;
}
.sdg-card:hover {
	transform: translateY(-0.25rem);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.5);
}
.sdg-number {
	width: 3rem;
	height: 3rem;
	border-radius: 0.75rem;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 1.25rem;
	font-weight: 800;
	margin-bottom: 1rem;
	color: #fff;
	transition: transform 0.3s ease;
}
.sdg-card:hover .sdg-number {
	transform: scale(1.1);
}
/* Official UN SDG colors */
.sdg-9 .sdg-number { background: #F36D25; }
.sdg-9:hover { border-color: rgba(243, 109, 37, 0.5); }
.sdg-8 .sdg-number { background: #8F1838; }
.sdg-8:hover { border-color: rgba(143, 24, 56, 0.5); }
.sdg-10 .sdg-number { background: #DD1367; }
.sdg-10:hover { border-color: rgba(221, 19, 103, 0.5); }
.sdg-12 .sdg-number { background: #CF8D2A; }
.sdg-12:hover { border-color: rgba(207, 141, 42, 0.5); }
.sdg-17 .sdg-number { background: #19486A; }
.sdg-17:hover { border-color: rgba(25, 72, 106, 0.5); }

html[data-theme='light'] .sdg-card {
	background: rgba(255, 255, 255, 0.7);
	border-color: rgba(228, 228, 231, 0.8);
}
html[data-theme='light'] .sdg-card:hover {
	background: rgba(255, 255, 255, 0.9);
	box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.1);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 48rem) {
	.unido-hero {
		padding: calc(var(--total-header-height, 6rem) + 2rem) 1.5rem 3rem;
		min-height: auto;
	}
}
</style>
