---
/**
 * Custom EDDI header that replaces Starlight's default Header component.
 * Renders inside Starlight's <header class="header"> wrapper.
 */
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
---

<div class="eddi-header-row">
	<div class="eddi-header-inner">
		<!-- Logo -->
		<div class="eddi-header-left">
			<SiteTitle />
		</div>

		<!-- Desktop Navigation -->
		<nav class="eddi-nav desktop-only" aria-label="Main navigation">
			<div class="eddi-nav-item has-dropdown">
				<button class="eddi-nav-link" aria-expanded="false" aria-haspopup="true">
					Features <svg class="eddi-chevron" viewBox="0 0 20 20" fill="currentColor" width="12" height="12"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
				</button>
				<div class="eddi-dropdown features-dropdown">
					<div class="eddi-dropdown-grid">
						<a href="/features/manager/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🖥️</span>
							<div>
								<strong>EDDI Manager</strong>
								<span>Visual agent management UI</span>
							</div>
						</a>
						<a href="/features/mcp-server/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🔌</span>
							<div>
								<strong>MCP Server</strong>
								<span>39 tools for AI-native control</span>
							</div>
						</a>
						<a href="/features/config-as-code/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">⚙️</span>
							<div>
								<strong>Config-as-Code</strong>
								<span>JSON config, not compiled Java</span>
							</div>
						</a>
						<a href="/features/security/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🔐</span>
							<div>
								<strong>Security-First</strong>
								<span>Vault, audit trails, no eval()</span>
							</div>
						</a>
						<a href="/features/performance/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🚀</span>
							<div>
								<strong>Performance</strong>
								<span>Java 25 Virtual Threads</span>
							</div>
						</a>
						<a href="/features/multi-agent/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🤖</span>
							<div>
								<strong>Multi-Agent</strong>
								<span>Intent routing & discovery</span>
							</div>
						</a>
						<a href="/features/observability/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">📊</span>
							<div>
								<strong>Observability</strong>
								<span>Pipeline logs & audit trails</span>
							</div>
						</a>
						<a href="/features/code-quality/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🧪</span>
							<div>
								<strong>Code Quality</strong>
								<span>1,000+ tests, zero failures</span>
							</div>
						</a>
						<a href="/features/ai-ready/" class="eddi-dropdown-item">
							<span class="eddi-dropdown-icon">🧩</span>
							<div>
								<strong>AI-Ready</strong>
								<span>Built for coding agents</span>
							</div>
						</a>
					</div>
					<div class="eddi-dropdown-footer">
						<a href="/features/overview/">View all features →</a>
					</div>
				</div>
			</div>

			<a href="/docs/getting-started/" class="eddi-nav-link">Docs</a>

			<div class="eddi-nav-item has-dropdown">
				<button class="eddi-nav-link" aria-expanded="false" aria-haspopup="true">
					Solutions <svg class="eddi-chevron" viewBox="0 0 20 20" fill="currentColor" width="12" height="12"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
				</button>
				<div class="eddi-dropdown solutions-dropdown">
					<a href="/enterprise/why-eddi/" class="eddi-dropdown-item">
						<span class="eddi-dropdown-icon">💡</span>
						<div>
							<strong>Why EDDI?</strong>
							<span>The only JVM-native visual AI middleware</span>
						</div>
					</a>
					<a href="/enterprise/vs-alternatives/" class="eddi-dropdown-item">
						<span class="eddi-dropdown-icon">⚖️</span>
						<div>
							<strong>vs. Alternatives</strong>
							<span>Compare with Spring AI, Flowise, n8n</span>
						</div>
					</a>
					<a href="/enterprise/compliance/" class="eddi-dropdown-item">
						<span class="eddi-dropdown-icon">🏛️</span>
						<div>
							<strong>EU AI Act</strong>
							<span>Compliance & governance</span>
						</div>
					</a>
					<a href="/docs/use-cases/" class="eddi-dropdown-item">
						<span class="eddi-dropdown-icon">📋</span>
						<div>
							<strong>Use Cases</strong>
							<span>Real-world deployment patterns</span>
						</div>
					</a>
				</div>
			</div>

			<a href="/docs/mcp/overview/" class="eddi-nav-link">MCP Tools</a>
			<a href="/docs/changelog/v6/" class="eddi-nav-link">Changelog</a>
		</nav>

		<!-- Right side -->
		<div class="eddi-header-right">
			<Search />
			<a href="/docs/getting-started/" class="eddi-cta desktop-only">Get Started</a>
			<a href="https://github.com/labsai/EDDI" class="eddi-icon-link desktop-only" aria-label="GitHub" target="_blank" rel="noopener">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
			</a>
			<div class="desktop-only"><ThemeSelect /></div>
			<button class="eddi-hamburger mobile-only" aria-label="Open menu" aria-expanded="false">
				<span class="eddi-hamburger-line"></span>
				<span class="eddi-hamburger-line"></span>
				<span class="eddi-hamburger-line"></span>
			</button>
		</div>
	</div>
</div>

<!-- Mobile menu overlay -->
<div class="eddi-mobile-menu" id="eddi-mobile-menu" aria-hidden="true">
	<div class="eddi-mobile-inner">
		<div class="eddi-mobile-section">
			<h3>Features</h3>
			<a href="/features/overview/">All Features</a>
			<a href="/features/manager/">EDDI Manager</a>
			<a href="/features/mcp-server/">MCP Server (39 Tools)</a>
			<a href="/features/config-as-code/">Config-as-Code</a>
			<a href="/features/security/">Security-First</a>
			<a href="/features/performance/">Performance</a>
			<a href="/features/multi-agent/">Multi-Agent</a>
			<a href="/features/observability/">Observability</a>
			<a href="/features/code-quality/">Code Quality</a>
			<a href="/features/ai-ready/">AI-Ready</a>
		</div>
		<div class="eddi-mobile-section">
			<h3>Documentation</h3>
			<a href="/docs/getting-started/">Getting Started</a>
			<a href="/docs/quickstart/">Quickstart</a>
			<a href="/docs/install-wizard/">Install Wizard</a>
			<a href="/docs/architecture/seven-pillars/">Architecture</a>
			<a href="/docs/mcp/overview/">MCP Tools</a>
			<a href="/docs/integrations/">Integrations</a>
			<a href="/docs/deployment/docker/">Docker & K8s</a>
			<a href="/docs/api/rest/">REST API</a>
		</div>
		<div class="eddi-mobile-section">
			<h3>Solutions</h3>
			<a href="/enterprise/why-eddi/">Why EDDI?</a>
			<a href="/enterprise/vs-alternatives/">vs. Alternatives</a>
			<a href="/enterprise/compliance/">EU AI Act</a>
			<a href="/docs/use-cases/">Use Cases</a>
		</div>
		<div class="eddi-mobile-section">
			<h3>Community</h3>
			<a href="https://github.com/labsai/EDDI" target="_blank" rel="noopener">GitHub ↗</a>
			<a href="/docs/roadmap/">Roadmap</a>
			<a href="/docs/changelog/v6/">Changelog</a>
		</div>
		<div class="eddi-mobile-cta">
			<a href="/docs/getting-started/" class="eddi-cta">Get Started</a>
		</div>
	</div>
</div>

<style>
	/* ===== HEADER ROW ===== */
	.eddi-header-row {
		display: flex;
		align-items: center;
		width: 100%;
	}

	.eddi-header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: 80rem;
		margin: 0 auto;
		padding: 0 1rem;
		height: 3.5rem;
	}

	.eddi-header-left {
		flex-shrink: 0;
	}

	/* ===== DESKTOP NAV ===== */
	.eddi-nav {
		display: flex;
		align-items: center;
		gap: 0.125rem;
	}

	.eddi-nav-item {
		position: relative;
	}

	.eddi-nav-link {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.4375rem 0.625rem;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: 0.9375rem;
		font-weight: 500;
		border-radius: 0.375rem;
		border: none;
		background: none;
		cursor: pointer;
		transition: color 0.15s, background 0.15s;
		white-space: nowrap;
		font-family: var(--sl-font);
	}

	.eddi-nav-link:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}

	.eddi-chevron {
		transition: transform 0.2s;
	}

	/* ===== DROPDOWNS ===== */
	.eddi-dropdown {
		position: absolute;
		top: calc(100% + 0.5rem);
		left: 50%;
		transform: translateX(-50%) translateY(4px);
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-gray-6);
		border-radius: 0.75rem;
		box-shadow: 0 20px 50px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.05);
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
		padding: 0.5rem;
		min-width: 15rem;
		z-index: 200;
	}

	.features-dropdown {
		min-width: 34rem;
	}

	.has-dropdown:hover .eddi-dropdown,
	.has-dropdown:focus-within .eddi-dropdown {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(0);
	}

	.has-dropdown:hover .eddi-chevron {
		transform: rotate(180deg);
	}

	.has-dropdown:hover > .eddi-nav-link {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}

	.eddi-dropdown-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.125rem;
	}

	.eddi-dropdown-item {
		display: flex;
		align-items: flex-start;
		gap: 0.625rem;
		padding: 0.5rem 0.625rem;
		border-radius: 0.375rem;
		text-decoration: none;
		color: var(--sl-color-gray-2);
		transition: background 0.15s;
	}

	.eddi-dropdown-item:hover {
		background: var(--sl-color-gray-6);
	}

	.eddi-dropdown-icon {
		font-size: 1.125rem;
		flex-shrink: 0;
		margin-top: 0.0625rem;
	}

	.eddi-dropdown-item strong {
		display: block;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--sl-color-white);
		margin-bottom: 0.0625rem;
	}

	.eddi-dropdown-item div span {
		font-size: 0.6875rem;
		color: var(--sl-color-gray-3);
		line-height: 1.3;
	}

	.eddi-dropdown-footer {
		border-top: 1px solid var(--sl-color-gray-6);
		margin-top: 0.375rem;
		padding-top: 0.375rem;
	}

	.eddi-dropdown-footer a {
		display: block;
		padding: 0.3125rem 0.625rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--sl-color-text-accent);
		text-decoration: none;
		border-radius: 0.25rem;
		transition: background 0.15s;
	}

	.eddi-dropdown-footer a:hover {
		background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
	}

	/* ===== RIGHT SIDE ===== */
	.eddi-header-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.eddi-cta {
		display: inline-flex;
		align-items: center;
		padding: 0.375rem 0.875rem;
		font-size: 0.8125rem;
		font-weight: 600;
		color: white !important;
		background: var(--sl-color-accent);
		border-radius: 0.375rem;
		text-decoration: none;
		transition: background 0.15s, box-shadow 0.15s;
		white-space: nowrap;
	}

	.eddi-cta:hover {
		background: color-mix(in srgb, var(--sl-color-accent) 85%, white);
		box-shadow: 0 0 16px color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
	}

	.eddi-icon-link {
		display: flex;
		align-items: center;
		padding: 0.25rem;
		color: var(--sl-color-gray-2);
		border-radius: 0.25rem;
		transition: color 0.15s;
	}

	.eddi-icon-link:hover {
		color: var(--sl-color-white);
	}

	/* ===== HAMBURGER ===== */
	.eddi-hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		width: 2rem;
		height: 2rem;
		padding: 0.375rem;
		background: none;
		border: none;
		cursor: pointer;
		border-radius: 0.25rem;
	}

	.eddi-hamburger:hover {
		background: var(--sl-color-gray-6);
	}

	.eddi-hamburger-line {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--sl-color-gray-2);
		border-radius: 1px;
		transition: transform 0.3s, opacity 0.3s;
	}

	.eddi-hamburger[aria-expanded="true"] .eddi-hamburger-line:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}
	.eddi-hamburger[aria-expanded="true"] .eddi-hamburger-line:nth-child(2) {
		opacity: 0;
	}
	.eddi-hamburger[aria-expanded="true"] .eddi-hamburger-line:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	/* ===== MOBILE MENU ===== */
	.eddi-mobile-menu {
		display: none;
		position: fixed;
		top: 4rem;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--sl-color-bg);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		transform: translateX(100%);
		transition: transform 0.3s ease;
		z-index: 99;
	}

	.eddi-mobile-menu[aria-hidden="false"] {
		transform: translateX(0);
	}

	.eddi-mobile-inner {
		padding: 1rem 1.25rem;
	}

	.eddi-mobile-section {
		margin-bottom: 1.25rem;
	}

	.eddi-mobile-section h3 {
		font-size: 0.625rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-3);
		margin: 0 0 0.375rem 0.625rem;
	}

	.eddi-mobile-section a {
		display: block;
		padding: 0.5rem 0.625rem;
		color: var(--sl-color-gray-1);
		text-decoration: none;
		font-size: 0.875rem;
		border-radius: 0.375rem;
		transition: background 0.15s;
	}

	.eddi-mobile-section a:hover {
		background: var(--sl-color-gray-6);
	}

	.eddi-mobile-cta {
		padding-top: 0.75rem;
		border-top: 1px solid var(--sl-color-gray-6);
	}

	.eddi-mobile-cta .eddi-cta {
		display: flex;
		justify-content: center;
		width: 100%;
		padding: 0.625rem;
		font-size: 0.9375rem;
	}

	/* ===== RESPONSIVE ===== */
	.desktop-only {
		display: flex;
	}
	.mobile-only {
		display: none !important;
	}

	@media (max-width: 64rem) {
		.desktop-only {
			display: none !important;
		}
		.mobile-only {
			display: flex !important;
		}
		.eddi-mobile-menu {
			display: block;
		}
	}

	/* ===== ACTIVE NAV ===== */
	:global(.eddi-nav-active) {
		color: var(--sl-color-text-accent) !important;
		background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent) !important;
	}

	/* ===== LIGHT MODE ===== */
	:global(html[data-theme='light']) .eddi-nav-link {
		color: var(--sl-color-gray-2);
	}

	:global(html[data-theme='light']) .eddi-nav-link:hover {
		color: var(--sl-color-black);
		background: var(--sl-color-gray-6);
	}

	:global(html[data-theme='light']) .has-dropdown:hover > .eddi-nav-link {
		color: var(--sl-color-black);
	}

	:global(html[data-theme='light']) .eddi-dropdown {
		background: var(--sl-color-bg-nav);
		border-color: var(--sl-color-gray-5);
		box-shadow: 0 20px 50px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.05);
	}

	:global(html[data-theme='light']) .eddi-dropdown-item {
		color: var(--sl-color-gray-2);
	}

	:global(html[data-theme='light']) .eddi-dropdown-item strong {
		color: var(--sl-color-black);
	}

	:global(html[data-theme='light']) .eddi-dropdown-item:hover {
		background: var(--sl-color-gray-6);
	}

	:global(html[data-theme='light']) .eddi-hamburger-line {
		background: var(--sl-color-gray-2);
	}

	:global(html[data-theme='light']) .eddi-mobile-section h3 {
		color: var(--sl-color-gray-3);
	}

	:global(html[data-theme='light']) .eddi-mobile-section a {
		color: var(--sl-color-gray-1);
	}

	:global(html[data-theme='light']) .eddi-icon-link {
		color: var(--sl-color-gray-2);
	}

	:global(html[data-theme='light']) .eddi-icon-link:hover {
		color: var(--sl-color-black);
	}
</style>

<script>
	function initEddiHeader() {
		const hamburger = document.querySelector('.eddi-hamburger');
		const mobileMenu = document.getElementById('eddi-mobile-menu');

		if (hamburger && mobileMenu) {
			hamburger.addEventListener('click', () => {
				const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
				hamburger.setAttribute('aria-expanded', String(!isOpen));
				mobileMenu.setAttribute('aria-hidden', String(isOpen));
				document.body.style.overflow = isOpen ? '' : 'hidden';
			});

			mobileMenu.querySelectorAll('a').forEach(link => {
				link.addEventListener('click', () => {
					hamburger.setAttribute('aria-expanded', 'false');
					mobileMenu.setAttribute('aria-hidden', 'true');
					document.body.style.overflow = '';
				});
			});
		}

		// Highlight active section
		const path = window.location.pathname;
		document.querySelectorAll('.eddi-nav > .eddi-nav-link, .eddi-nav > .eddi-nav-item > .eddi-nav-link').forEach(el => {
			const link = el as HTMLElement;
			const href = link.getAttribute('href') || '';
			const parent = link.closest('.eddi-nav-item');
			const firstDropdownHref = parent?.querySelector('.eddi-dropdown-item')?.getAttribute('href') || '';

			const checkHref = href || firstDropdownHref;
			if (
				(checkHref.startsWith('/features/') && path.startsWith('/features/')) ||
				(checkHref.startsWith('/docs/getting-started') && path.startsWith('/docs/') && !path.startsWith('/docs/mcp/') && !path.startsWith('/docs/changelog/') && !path.startsWith('/docs/use-cases/') && !path.startsWith('/docs/roadmap/') && !path.startsWith('/docs/integrations/')) ||
				(checkHref.startsWith('/docs/mcp/') && path.startsWith('/docs/mcp/')) ||
				(checkHref.startsWith('/docs/changelog/') && path.startsWith('/docs/changelog/')) ||
				((checkHref.startsWith('/enterprise/') || checkHref.startsWith('/docs/use-cases/')) && (path.startsWith('/enterprise/') || path.startsWith('/docs/use-cases/')))
			) {
				link.classList.add('eddi-nav-active');
			}
		});
	}

	initEddiHeader();
	document.addEventListener('astro:after-swap', initEddiHeader);
</script>
