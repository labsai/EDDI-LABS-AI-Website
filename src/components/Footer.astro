---
/**
 * Custom EDDI footer — standalone (no Starlight dependencies).
 * i18n-aware: all text from translations, all links locale-prefixed.
 */
import eddiLogoDark from '../assets/eddi-logo-dark.svg';
import eddiLogoLight from '../assets/eddi-logo-light.svg';
import { localePath, getLocaleFromUrl, getTranslations, type Locale } from '../i18n';

interface Props {
	lang?: Locale;
}

const lang = Astro.props.lang ?? getLocaleFromUrl(Astro.url);
const t = await getTranslations(lang);
---

<footer class="eddi-site-footer">
	<div class="eddi-footer-inner">

		<!-- Trust bar -->
		<div class="eddi-trust-bar">
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
				<span>{t.footer.redHatCertified}</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
				<span>{t.footer.apache2}</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
				<span>{t.footer.tests}</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
				<span>{t.footer.techStack}</span>
			</div>
		</div>

		<div class="eddi-footer-divider"></div>

		<!-- Footer grid -->
		<div class="eddi-footer-grid">
			<!-- Brand column -->
			<div class="eddi-footer-brand">
				<a href={localePath(lang, '/')} class="eddi-footer-logo" aria-label="EDDI Home">
					<img src={eddiLogoDark.src} alt="EDDI" class="eddi-footer-logo-img eddi-footer-logo-dark" width="120" height="38" />
					<img src={eddiLogoLight.src} alt="EDDI" class="eddi-footer-logo-img eddi-footer-logo-light" width="120" height="38" />
				</a>
				<p class="eddi-footer-tagline">{t.footer.tagline}</p>
				<p class="eddi-footer-sub">{t.footer.subtitle}</p>
				<div class="eddi-footer-social">
					<a href="https://github.com/labsai/EDDI" target="_blank" rel="noopener" aria-label="GitHub">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
				</div>
			</div>

			<!-- Platform column -->
			<div class="eddi-footer-col">
				<h3>{t.footer.platform}</h3>
				<a href={localePath(lang, '/features/overview/')}>{t.footer.featuresOverview}</a>
				<a href={localePath(lang, '/features/mcp-server/')}>{t.footer.mcpServer}</a>
				<a href={localePath(lang, '/features/config-as-code/')}>{t.footer.configAsCode}</a>
				<a href={localePath(lang, '/features/security/')}>{t.footer.securityFirst}</a>
				<a href={localePath(lang, '/features/performance/')}>{t.footer.performanceLink}</a>
				<a href={localePath(lang, '/features/multi-agent/')}>{t.footer.multiAgent}</a>
				<a href={localePath(lang, '/features/memory/')}>{t.footer.memoryLink}</a>
				<a href={localePath(lang, '/features/rag/')}>{t.footer.ragLink}</a>
				<a href={localePath(lang, '/features/model-cascading/')}>{t.footer.modelCascadingLink}</a>
				<a href={localePath(lang, '/features/scheduling/')}>{t.footer.schedulingLink}</a>
			</div>

			<!-- Develop column -->
			<div class="eddi-footer-col">
				<h3>{t.footer.develop}</h3>
				<a href={localePath(lang, '/getting-started/')}>{t.footer.gettingStarted}</a>
				<a href="https://docs.labs.ai" target="_blank" rel="noopener">{t.footer.documentation}</a>
				<a href="https://github.com/labsai/EDDI" target="_blank" rel="noopener">{t.footer.githubLink}</a>
			</div>

			<!-- Resources column -->
			<div class="eddi-footer-col">
				<h3>{t.footer.resourcesCol}</h3>
				<a href={localePath(lang, '/enterprise/why-eddi/')}>{t.footer.whyEddi}</a>
				<a href={localePath(lang, '/enterprise/vs-alternatives/')}>{t.footer.vsAlternatives}</a>
				<a href={localePath(lang, '/enterprise/compliance/')}>{t.footer.euAiAct}</a>
				<a href={localePath(lang, '/enterprise/trust/')}>{t.footer.trackRecord}</a>
				<a href={localePath(lang, '/use-cases/')}>{t.footer.useCases}</a>
			</div>

			<!-- Community column -->
			<div class="eddi-footer-col">
				<h3>{t.footer.communityCol}</h3>
				<a href="https://github.com/labsai/EDDI/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">{t.footer.contributing}</a>
				<a href="https://github.com/labsai/EDDI/issues/new?template=bug_report.yml" target="_blank" rel="noopener">{t.footer.reportBug}</a>
				<a href="https://github.com/labsai/EDDI/blob/main/SECURITY.md" target="_blank" rel="noopener">{t.footer.securityPolicy}</a>
				<a href="https://github.com/labsai/EDDI/blob/main/CODE_OF_CONDUCT.md" target="_blank" rel="noopener">{t.footer.codeOfConduct}</a>
				<a href="https://github.com/labsai/EDDI/discussions" target="_blank" rel="noopener">{t.footer.discussions}</a>
				<a href={localePath(lang, '/contact/')}>{t.footer.contactLink}</a>
				<a href={localePath(lang, '/imprint/')}>{t.legal.imprintLink}</a>
				<a href={localePath(lang, '/privacy/')}>{t.legal.privacyLink}</a>
			</div>
		</div>

		<div class="eddi-footer-divider"></div>

		<!-- Bottom bar -->
		<div class="eddi-footer-bottom">
			<p>© {new Date().getFullYear()} <a href="https://labs.ai" target="_blank" rel="noopener">Labs.ai</a> · <a href="https://github.com/labsai/EDDI/blob/main/LICENSE" target="_blank" rel="noopener">Apache 2.0</a> · <a href={localePath(lang, '/imprint/')}>{t.legal.imprintLink}</a> · <a href={localePath(lang, '/privacy/')}>{t.legal.privacyLink}</a></p>
			<p>{t.footer.initiated}</p>
		</div>
	</div>
</footer>

<style>
	.eddi-site-footer {
		border-top: 1px solid var(--color-border);
		margin-top: 3rem;
	}

	html[data-theme='dark'] .eddi-site-footer {
		background: rgba(3, 3, 5, 0.9);
	}
	html[data-theme='light'] .eddi-site-footer {
		background: #f5f6f8;
	}

	.eddi-footer-inner {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ===== TRUST BAR ===== */
	.eddi-trust-bar {
		display: flex;
		justify-content: center;
		gap: 2rem;
		padding: 1.25rem 0;
		flex-wrap: wrap;
	}

	.eddi-trust-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-text-subtle);
		white-space: nowrap;
	}

	.eddi-trust-item svg {
		color: var(--color-accent);
		flex-shrink: 0;
	}

	/* ===== DIVIDER ===== */
	.eddi-footer-divider {
		height: 1px;
		background: var(--color-border);
	}

	/* ===== FOOTER GRID ===== */
	.eddi-footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
		gap: 2rem;
		padding: 2rem 0;
	}

	/* Brand */
	.eddi-footer-brand {
		padding-inline-end: 1rem;
	}

	.eddi-footer-logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.125rem;
		text-decoration: none;
	}

	.eddi-footer-logo-img {
		height: 1.5rem;
		width: auto;
	}

	.eddi-footer-logo-dark { display: block; }
	.eddi-footer-logo-light { display: none; }
	html[data-theme='light'] .eddi-footer-logo-dark { display: none !important; }
	html[data-theme='light'] .eddi-footer-logo-light { display: block !important; }

	.eddi-footer-tagline {
		margin: 0.5rem 0 0.125rem;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-text-muted);
	}

	.eddi-footer-sub {
		margin: 0;
		font-size: 0.75rem;
		color: var(--color-text-subtle);
		line-height: 1.4;
	}

	.eddi-footer-social {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.875rem;
	}

	.eddi-footer-social a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		color: var(--color-text-subtle);
		background: var(--color-surface);
		border-radius: 0.375rem;
		transition: color 0.15s, background 0.15s;
	}

	.eddi-footer-social a:hover {
		color: var(--color-text);
		background: var(--color-border);
	}

	/* ===== COLUMNS ===== */
	.eddi-footer-col {
		display: flex;
		flex-direction: column;
	}

	.eddi-footer-col h3 {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text-muted);
		margin: 0 0 0.625rem;
	}

	.eddi-footer-col a {
		display: block;
		padding: 0.375rem 0;
		font-size: 0.8125rem;
		color: var(--color-text-subtle);
		text-decoration: none;
		transition: color 0.15s;
	}

	.eddi-footer-col a:hover {
		color: var(--color-text);
	}

	/* ===== BOTTOM BAR ===== */
	.eddi-footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 0;
	}

	.eddi-footer-bottom p {
		font-size: 0.6875rem;
		color: var(--color-text-subtle);
		margin: 0;
	}

	.eddi-footer-bottom a {
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.eddi-footer-bottom a:hover {
		color: var(--color-text);
	}

	/* ===== RESPONSIVE ===== */
	@media (max-width: 64rem) {
		.eddi-footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
		.eddi-footer-brand {
			grid-column: 1 / -1;
			padding-inline-end: 0;
		}

		.eddi-trust-bar {
			gap: 1rem;
		}
	}

	@media (max-width: 30rem) {
		.eddi-footer-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		.eddi-footer-bottom {
			flex-direction: column;
			gap: 0.25rem;
			text-align: center;
		}
		.eddi-trust-bar {
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
		}
	}
</style>
