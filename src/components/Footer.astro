---
/**
 * Custom EDDI footer with premium design.
 * Extends Starlight's default Footer (pagination/edit/lastUpdated).
 * The branded site-wide footer is only shown on non-docs pages (homepage, features, enterprise).
 */
import Default from '@astrojs/starlight/components/Footer.astro';

const isDocsPage = Astro.url.pathname.startsWith('/docs/');

import eddiLogoDark from '../assets/eddi-logo-dark.svg';
import eddiLogoLight from '../assets/eddi-logo-light.svg';
---

<!-- Starlight's default footer (pagination, edit link, last updated) -->
<Default><slot /></Default>

{!isDocsPage && (
<!-- Site-wide footer (hidden on docs pages) -->
<footer class="eddi-site-footer not-content">
	<div class="eddi-footer-inner">

		<!-- Trust bar -->
		<div class="eddi-trust-bar">
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
				<span>Red Hat Certified Container</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
				<span>Apache 2.0 Licensed</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
				<span>1,000+ Tests · Zero Failures</span>
			</div>
			<div class="eddi-trust-item">
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
				<span>Java 25 · Quarkus · LangChain4j</span>
			</div>
		</div>

		<div class="eddi-footer-divider"></div>

		<!-- Footer grid -->
		<div class="eddi-footer-grid">
			<!-- Brand column -->
			<div class="eddi-footer-brand">
				<a href="/" class="eddi-footer-logo" aria-label="EDDI Home">
					<img src={eddiLogoDark.src} alt="EDDI" class="eddi-footer-logo-img eddi-footer-logo-dark" width="80" height="20" />
					<img src={eddiLogoLight.src} alt="EDDI" class="eddi-footer-logo-img eddi-footer-logo-light" width="80" height="20" />
				</a>
				<p class="eddi-footer-tagline">The Enterprise AI Orchestrator</p>
				<p class="eddi-footer-sub">Configuration-driven. Java-native. Production-ready.</p>
				<div class="eddi-footer-social">
					<a href="https://github.com/labsai/EDDI" target="_blank" rel="noopener" aria-label="GitHub">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
				</div>
			</div>

			<!-- Platform column -->
			<div class="eddi-footer-col">
				<h3>Platform</h3>
				<a href="/features/overview/">Features Overview</a>
				<a href="/features/mcp-server/">MCP Server</a>
				<a href="/features/config-as-code/">Config-as-Code</a>
				<a href="/features/security/">Security-First</a>
				<a href="/features/performance/">Performance</a>
				<a href="/features/multi-agent/">Multi-Agent</a>
			</div>

			<!-- Develop column -->
			<div class="eddi-footer-col">
				<h3>Develop</h3>
				<a href="/docs/getting-started/">Getting Started</a>
				<a href="/docs/quickstart/">Quickstart</a>
				<a href="/docs/install-wizard/">Install Wizard</a>
				<a href="/docs/mcp/overview/">MCP Tools</a>
				<a href="/docs/integrations/">Integrations</a>
				<a href="/docs/api/rest/">REST API</a>
			</div>

			<!-- Resources column -->
			<div class="eddi-footer-col">
				<h3>Resources</h3>
				<a href="/enterprise/why-eddi/">Why EDDI?</a>
				<a href="/enterprise/vs-alternatives/">vs. Alternatives</a>
				<a href="/enterprise/compliance/">EU AI Act</a>
				<a href="/docs/use-cases/">Use Cases</a>
				<a href="/docs/roadmap/">Roadmap</a>
				<a href="/docs/changelog/v6/">Changelog</a>
			</div>
		</div>

		<div class="eddi-footer-divider"></div>

		<!-- Bottom bar -->
		<div class="eddi-footer-bottom">
			<p>© {new Date().getFullYear()} <a href="https://labs.ai" target="_blank" rel="noopener">Labs.ai</a> · <a href="https://github.com/labsai/EDDI/blob/main/LICENSE" target="_blank" rel="noopener">Apache 2.0</a></p>
			<p>Initiated in Vienna. Developed with ❤️ in Europe. Made for the World.</p>
		</div>
	</div>
</footer>
)}

<style is:global>
	.eddi-site-footer {
		background: color-mix(in srgb, var(--sl-color-bg) 90%, black);
		border-top: 1px solid var(--sl-color-gray-6);
		margin-top: 3rem;
		/* Break out of Starlight container to be full width */
		width: 100vw;
		position: relative;
		left: 50%;
		right: 50%;
		margin-left: -50vw;
		margin-right: -50vw;
	}

	.eddi-footer-inner {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	/* ===== TRUST BAR ===== */
	.eddi-trust-bar {
		display: flex;
		justify-content: center;
		gap: 2rem;
		padding: 1.25rem 0;
		flex-wrap: wrap;
	}

	.eddi-trust-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--sl-color-gray-3);
		white-space: nowrap;
	}

	.eddi-trust-item svg {
		color: var(--sl-color-text-accent);
		flex-shrink: 0;
	}

	/* ===== DIVIDER ===== */
	.eddi-footer-divider {
		height: 1px;
		background: var(--sl-color-gray-6);
	}

	/* ===== FOOTER GRID ===== */
	.eddi-footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr 1fr;
		gap: 2rem;
		padding: 2rem 0;
	}

	/* Brand */
	.eddi-footer-brand {
		padding-right: 1rem;
	}

	.eddi-footer-logo {
		display: inline-flex;
		align-items: baseline;
		gap: 0.125rem;
		text-decoration: none;
	}

	.eddi-footer-logo-img {
		height: 1.5rem;
		width: auto;
	}

	/* Dark mode: show dark logo, hide light */
	.eddi-footer-logo-dark {
		display: block;
	}
	.eddi-footer-logo-light {
		display: none;
	}

	html[data-theme='light'] .eddi-footer-logo-dark {
		display: none !important;
	}
	html[data-theme='light'] .eddi-footer-logo-light {
		display: block !important;
	}

	.eddi-logo-text {
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--sl-color-white);
	}

	.eddi-logo-slash {
		font-size: 1.25rem;
		font-weight: 400;
		color: var(--sl-color-text-accent);
		opacity: 0.8;
	}

	.eddi-footer-tagline {
		margin: 0.5rem 0 0.125rem;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--sl-color-gray-2);
	}

	.eddi-footer-sub {
		margin: 0;
		font-size: 0.75rem;
		color: var(--sl-color-gray-4);
		line-height: 1.4;
	}

	.eddi-footer-social {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.875rem;
	}

	.eddi-footer-social a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		color: var(--sl-color-gray-3);
		background: var(--sl-color-gray-6);
		border-radius: 0.375rem;
		transition: color 0.15s, background 0.15s;
	}

	.eddi-footer-social a:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-5);
	}

	/* ===== COLUMNS ===== */
	.eddi-footer-col {
		display: flex;
		flex-direction: column;
	}

	.eddi-footer-col h3 {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sl-color-gray-2);
		margin: 0 0 0.625rem;
	}

	.eddi-footer-col a {
		display: block;
		padding: 0.2rem 0;
		font-size: 0.8125rem;
		color: var(--sl-color-gray-3);
		text-decoration: none;
		transition: color 0.15s;
	}

	.eddi-footer-col a:hover {
		color: var(--sl-color-white);
	}

	/* ===== BOTTOM BAR ===== */
	.eddi-footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 0;
	}

	.eddi-footer-bottom p {
		font-size: 0.6875rem;
		color: var(--sl-color-gray-4);
		margin: 0;
	}

	.eddi-footer-bottom a {
		color: var(--sl-color-gray-3);
		text-decoration: none;
	}

	.eddi-footer-bottom a:hover {
		color: var(--sl-color-white);
	}

	/* ===== RESPONSIVE ===== */
	@media (max-width: 64rem) {
		.eddi-footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
		.eddi-footer-brand {
			grid-column: 1 / -1;
			padding-right: 0;
		}
		.eddi-trust-bar {
			gap: 1rem;
		}
	}

	/* ===== LIGHT MODE OVERRIDES ===== */
	html[data-theme='light'] .eddi-site-footer {
		background: color-mix(in srgb, var(--sl-color-gray-6) 20%, white) !important;
	}

	html[data-theme='light'] .eddi-trust-item {
		color: var(--sl-color-gray-2);
	}

	html[data-theme='light'] .eddi-footer-col h3 {
		color: var(--sl-color-gray-1);
	}

	html[data-theme='light'] .eddi-footer-col a {
		color: var(--sl-color-gray-2);
	}

	html[data-theme='light'] .eddi-footer-col a:hover {
		color: var(--sl-color-black);
	}

	html[data-theme='light'] .eddi-footer-tagline {
		color: var(--sl-color-gray-1);
	}

	html[data-theme='light'] .eddi-footer-sub {
		color: var(--sl-color-gray-3);
	}

	html[data-theme='light'] .eddi-footer-social a {
		color: var(--sl-color-gray-2);
		background: var(--sl-color-gray-6);
	}

	html[data-theme='light'] .eddi-footer-social a:hover {
		color: var(--sl-color-black);
		background: var(--sl-color-gray-5);
	}

	html[data-theme='light'] .eddi-footer-bottom p {
		color: var(--sl-color-gray-3);
	}

	html[data-theme='light'] .eddi-footer-bottom a {
		color: var(--sl-color-gray-2);
	}

	html[data-theme='light'] .eddi-footer-bottom a:hover {
		color: var(--sl-color-black);
	}

	@media (max-width: 30rem) {
		.eddi-footer-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
		.eddi-footer-bottom {
			flex-direction: column;
			gap: 0.25rem;
			text-align: center;
		}
		.eddi-trust-bar {
			flex-direction: column;
			align-items: center;
			gap: 0.5rem;
		}
	}
</style>

