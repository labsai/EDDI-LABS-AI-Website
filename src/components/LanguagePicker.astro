---
/**
 * Language Picker — Globe icon dropdown for switching between locales.
 * Matches the header's existing design aesthetic.
 */
import { LOCALES, LOCALE_CODES, getPathWithoutLocale, localePath, type Locale } from '../i18n';

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const pagePath = getPathWithoutLocale(Astro.url);
---

<div class="lang-picker">
	<button class="lang-picker-btn" aria-label="Select language" aria-expanded="false" aria-haspopup="true">
		<svg class="lang-globe" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="10"/>
			<line x1="2" y1="12" x2="22" y2="12"/>
			<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
		</svg>
		<span class="lang-code">{lang.toUpperCase()}</span>
	</button>
	<div class="lang-dropdown" role="menu">
		{LOCALE_CODES.map((loc) => (
			<a
				href={localePath(loc, pagePath)}
				class:list={['lang-dropdown-item', { active: loc === lang }]}
				role="menuitem"
				aria-current={loc === lang ? 'page' : undefined}
			>
				<span class="lang-native">{LOCALES[loc].native}</span>
				<span class="lang-label">{loc.toUpperCase()}</span>
			</a>
		))}
	</div>
</div>

<style>
	.lang-picker {
		position: relative;
	}

	.lang-picker-btn {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.375rem 0.5rem;
		background: none;
		border: none;
		border-radius: 0.375rem;
		cursor: pointer;
		color: var(--color-text-muted);
		transition: color 0.15s, background 0.15s;
		font-family: inherit;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.lang-picker-btn:hover {
		color: var(--color-text);
		background: var(--color-surface);
	}

	.lang-code {
		letter-spacing: 0.02em;
	}

	.lang-dropdown {
		position: absolute;
		top: calc(100% + 0.5rem);
		inset-inline-end: 0;
		min-width: 11rem;
		max-height: 24rem;
		overflow-y: auto;
		background: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.05);
		padding: 0.375rem;
		opacity: 0;
		visibility: hidden;
		transform: translateY(4px);
		transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
		z-index: 200;
	}

	html[data-theme='light'] .lang-dropdown {
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1), 0 0 0 1px rgba(0, 0, 0, 0.05);
	}

	.lang-picker:hover .lang-dropdown,
	.lang-picker:focus-within .lang-dropdown {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.lang-dropdown-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.4375rem 0.625rem;
		border-radius: 0.375rem;
		text-decoration: none;
		color: var(--color-text-muted);
		font-size: 0.8125rem;
		transition: background 0.15s, color 0.15s;
	}

	.lang-dropdown-item:hover {
		background: var(--color-surface);
		color: var(--color-text);
	}

	.lang-dropdown-item.active {
		color: var(--color-accent);
		font-weight: 600;
	}

	.lang-dropdown-item.active::before {
		content: '';
		position: absolute;
		inset-inline-start: 0.25rem;
		width: 3px;
		height: 1.25rem;
		border-radius: 2px;
		background: var(--color-accent);
	}

	.lang-native {
		font-weight: 500;
	}

	.lang-label {
		font-size: 0.6875rem;
		color: var(--color-text-subtle);
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.lang-dropdown-item.active .lang-label {
		color: color-mix(in srgb, var(--color-accent) 60%, transparent);
	}
</style>

<script>
	// Store explicit language choice when user clicks a language
	function initLangPicker() {
		document.querySelectorAll('.lang-dropdown-item').forEach(link => {
			link.addEventListener('click', () => {
				const href = link.getAttribute('href') || '';
				const segments = href.split('/').filter(Boolean);
				if (segments.length > 0) {
					localStorage.setItem('eddi-lang', segments[0]);
				}
			});
		});
	}
	initLangPicker();
	document.addEventListener('astro:after-swap', initLangPicker);
</script>
