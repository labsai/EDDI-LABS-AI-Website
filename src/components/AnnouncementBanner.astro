---
/**
 * Promotional Announcement Banner
 * Displays across the top of the header.
 * i18n-aware: all text from translations.
 */
import { localePath, getLocaleFromUrl, getTranslations } from '../i18n';

const lang = getLocaleFromUrl(Astro.url);
const t = await getTranslations(lang);
---
<div id="eddi-announcement-banner" class="announcement-banner">
	<div class="announcement-content">
		<span class="announcement-badge">{t.common.bannerBadge}</span>
		<p class="announcement-text">
			{t.common.bannerText}
			<a href={localePath(lang, '/getting-started/')} class="announcement-link">
				{t.common.bannerLink} <span class="announcement-arrow" aria-hidden="true">&rarr;</span>
			</a>
		</p>
		<button id="eddi-dismiss-banner" aria-label="Dismiss banner" class="announcement-close" title="Dismiss">
			<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="18" y1="6" x2="6" y2="18"></line>
				<line x1="6" y1="6" x2="18" y2="18"></line>
			</svg>
		</button>
	</div>
</div>

<style>
	.announcement-banner {
		background: linear-gradient(90deg, var(--color-accent-800), var(--color-accent-600));
		color: #ffffff;
		padding: 0.5rem 1rem;
		text-align: center;
		font-size: 0.875rem;
		position: fixed;
		top: var(--nav-height, 4rem);
		inset-inline-start: 0;
		inset-inline-end: 0;
		z-index: 99;
	}

	html[data-theme='light'] .announcement-banner {
		background: linear-gradient(90deg, var(--color-accent-500), var(--color-accent-400));
	}

	.announcement-content {
		max-width: 72rem;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
		position: relative;
		padding-inline-end: 2rem;
	}

	.announcement-badge {
		background: rgba(0, 0, 0, 0.2);
		padding: 0.125rem 0.5rem;
		border-radius: 9999px;
		font-weight: 700;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.announcement-text {
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.announcement-text strong {
		font-weight: 700;
	}

	.announcement-link {
		color: #ffffff;
		font-weight: 600;
		text-decoration: underline;
		text-decoration-color: rgba(255, 255, 255, 0.4);
		text-underline-offset: 4px;
		transition: text-decoration-color 0.2s;
	}

	.announcement-link:hover {
		text-decoration-color: #ffffff;
	}

	.announcement-close {
		position: absolute;
		inset-inline-end: 0;
		top: 50%;
		transform: translateY(-50%);
		background: none;
		border: none;
		color: rgba(255, 255, 255, 0.7);
		cursor: pointer;
		padding: 0.25rem;
		border-radius: 0.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s, background-color 0.2s;
	}

	.announcement-close:hover {
		color: #ffffff;
		background-color: rgba(255, 255, 255, 0.1);
	}

	.announcement-close svg {
		width: 1rem;
		height: 1rem;
	}

	@media (max-width: 640px) {
		.announcement-banner {
			font-size: 0.75rem;
			padding: 0.375rem 0.75rem;
		}
		.announcement-text {
			gap: 0.25rem;
		}
		.announcement-badge {
			font-size: 0.625rem;
			padding: 0.125rem 0.375rem;
		}
	}

	/* RTL: flip the arrow direction */
	html[dir="rtl"] .announcement-arrow {
		display: inline-block;
		transform: scaleX(-1);
	}
</style>

<script is:inline>
	(function() {
		if (localStorage.getItem('eddi-banner-dismissed') === 'true') {
			var banner = document.getElementById('eddi-announcement-banner');
			if (banner) banner.style.display = 'none';
		}
	})();
</script>

<script>
	document.addEventListener('astro:page-load', () => {
		const banner = document.getElementById('eddi-announcement-banner');
		const dismissBtn = document.getElementById('eddi-dismiss-banner');

		// Re-check dismissed state on SPA navigation (ClientRouter)
		if (banner && localStorage.getItem('eddi-banner-dismissed') === 'true') {
			banner.style.display = 'none';
			window.dispatchEvent(new Event('resize'));
			return;
		}
		
		if (banner && dismissBtn) {
			dismissBtn.addEventListener('click', () => {
				banner.style.display = 'none';
				localStorage.setItem('eddi-banner-dismissed', 'true');
				// Dispatch event so BaseLayout can recalculate height
				window.dispatchEvent(new Event('resize'));
			});
		}
	});
</script>
