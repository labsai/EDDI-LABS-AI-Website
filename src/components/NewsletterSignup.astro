---
/**
 * Newsletter Signup — HubSpot embedded form.
 * Renders a styled section with the HubSpot newsletter form.
 * i18n-aware: title and description from translations.
 */
import { getLocaleFromUrl, getTranslations, type Locale } from '../i18n';

interface Props {
	id?: string;
	lang?: Locale;
}

const { id = 'newsletter', lang: langProp } = Astro.props;
const lang = langProp ?? getLocaleFromUrl(Astro.url);
const t = await getTranslations(lang);
---

<section class="newsletter-section" id={id}>
	<div class="newsletter-glow"></div>
	<div class="newsletter-inner">
		<div class="newsletter-content">
			<div class="newsletter-icon">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2"/>
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
				</svg>
			</div>
			<h2 class="newsletter-title">{t.newsletter.title}</h2>
			<p class="newsletter-desc">{t.newsletter.description}</p>
		</div>
		<div class="newsletter-form-wrapper" id={`hs-form-${id}`}></div>
	</div>
</section>

<script>
	// Track active observers so we can clean them up on re-init
	let formObservers: MutationObserver[] = [];
	let themeObserver: MutationObserver | null = null;

	// Inject a global stylesheet that beats HubSpot's own injected styles
	function ensureHubSpotOverrideStyle() {
		if (document.getElementById('eddi-hs-override')) return;
		const style = document.createElement('style');
		style.id = 'eddi-hs-override';
		style.textContent = `
			/* Dark mode: force all HubSpot form text to be light */
			html[data-theme='dark'] .newsletter-form-wrapper label,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-form label,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-form-field > label,
			html[data-theme='dark'] .newsletter-form-wrapper [class*='hs-'] label {
				color: rgba(255, 255, 255, 0.9) !important;
			}
			html[data-theme='dark'] .newsletter-form-wrapper .legal-consent-container label,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-form-booleancheckbox label,
			html[data-theme='dark'] .newsletter-form-wrapper .legal-consent-container p,
			html[data-theme='dark'] .newsletter-form-wrapper .legal-consent-container span,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-richtext p,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-form-booleancheckbox-display span,
			html[data-theme='dark'] .newsletter-form-wrapper p,
			html[data-theme='dark'] .newsletter-form-wrapper span:not(.hs-form-required),
			html[data-theme='dark'] .newsletter-form-wrapper li {
				color: rgba(255, 255, 255, 0.7) !important;
			}
			html[data-theme='dark'] .newsletter-form-wrapper .hs-input:not([type='checkbox']),
			html[data-theme='dark'] .newsletter-form-wrapper input:not([type='checkbox']):not([type='submit']):not([type='hidden']) {
				background: rgba(255, 255, 255, 0.06) !important;
				color: #fff !important;
				border-color: rgba(255, 255, 255, 0.18) !important;
			}
			html[data-theme='dark'] .newsletter-form-wrapper .hs-form-required {
				color: var(--color-accent) !important;
			}
			html[data-theme='dark'] .newsletter-form-wrapper .legal-consent-container a {
				color: var(--color-accent) !important;
			}
			html[data-theme='dark'] .newsletter-form-wrapper .hs-error-msg,
			html[data-theme='dark'] .newsletter-form-wrapper .hs-error-msgs label {
				color: #f56565 !important;
			}
			.newsletter-form-wrapper .hubspot-link__container {
				display: none !important;
			}
		`;
		document.head.appendChild(style);
	}

	function applyThemeToForms() {
		ensureHubSpotOverrideStyle();
		const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

		// Style all form labels
		document.querySelectorAll('.newsletter-form-wrapper label').forEach((el) => {
			const label = el as HTMLElement;
			const isConsent = label.closest('.legal-consent-container') || label.closest('.hs-form-booleancheckbox');
			if (isConsent) {
				label.style.setProperty('color', isDark ? 'rgba(255, 255, 255, 0.7)' : 'rgba(0, 0, 0, 0.45)', 'important');
			} else {
				label.style.setProperty('color', isDark ? 'rgba(255, 255, 255, 0.9)' : 'rgba(0, 0, 0, 0.65)', 'important');
				label.style.fontSize = '0.8125rem';
				label.style.fontWeight = '500';
				label.style.marginBottom = '0.375rem';
				label.style.display = 'block';
			}
		});

		// Style all consent/legal text — higher contrast for readability
		document.querySelectorAll('.newsletter-form-wrapper .legal-consent-container p, .newsletter-form-wrapper .legal-consent-container span, .newsletter-form-wrapper .hs-richtext p').forEach((el) => {
			(el as HTMLElement).style.setProperty('color', isDark ? 'rgba(255, 255, 255, 0.7)' : 'rgba(0, 0, 0, 0.45)', 'important');
		});

		// Style consent checkbox text
		document.querySelectorAll('.newsletter-form-wrapper .hs-form-booleancheckbox-display span').forEach((el) => {
			(el as HTMLElement).style.setProperty('color', isDark ? 'rgba(255, 255, 255, 0.7)' : 'rgba(0, 0, 0, 0.45)', 'important');
		});

		// Style inputs
		document.querySelectorAll('.newsletter-form-wrapper .hs-input').forEach((el) => {
			const input = el as HTMLElement;
			if (input.tagName === 'INPUT' && (input as HTMLInputElement).type === 'checkbox') return;
			input.style.setProperty('background', isDark ? 'rgba(255, 255, 255, 0.06)' : '#fff', 'important');
			input.style.setProperty('color', isDark ? '#fff' : '#111', 'important');
			input.style.setProperty('border-color', isDark ? 'rgba(255, 255, 255, 0.18)' : 'rgba(0, 0, 0, 0.15)', 'important');
			input.style.width = '100%';
			input.style.padding = '0.75rem 1rem';
			input.style.fontSize = '0.9375rem';
			input.style.fontFamily = "'Outfit', sans-serif";
			input.style.borderRadius = '0.5rem';
			input.style.outline = 'none';
		});

		// Style submit buttons
		document.querySelectorAll('.newsletter-form-wrapper .hs-button').forEach((el) => {
			const btn = el as HTMLElement;
			btn.style.setProperty('background', 'linear-gradient(135deg, var(--color-accent-400), var(--color-accent-600))', 'important');
			btn.style.setProperty('color', '#111', 'important');
			btn.style.setProperty('border', 'none', 'important');
			btn.style.display = 'inline-flex';
			btn.style.alignItems = 'center';
			btn.style.justifyContent = 'center';
			btn.style.padding = '0.75rem 2rem';
			btn.style.fontSize = '0.9375rem';
			btn.style.fontWeight = '600';
			btn.style.fontFamily = "'Outfit', sans-serif";
			btn.style.borderRadius = '0.5rem';
			btn.style.cursor = 'pointer';
			btn.style.width = '100%';
			btn.style.boxShadow = '0 0 20px color-mix(in srgb, var(--color-accent) 25%, transparent)';
		});

		// Hide HubSpot branding
		document.querySelectorAll('.newsletter-form-wrapper .hubspot-link__container').forEach((el) => {
			(el as HTMLElement).style.display = 'none';
		});

		// Style legal links
		document.querySelectorAll('.newsletter-form-wrapper .legal-consent-container a').forEach((el) => {
			(el as HTMLElement).style.setProperty('color', 'var(--color-accent)', 'important');
		});

		// Style required asterisks
		document.querySelectorAll('.newsletter-form-wrapper .hs-form-required').forEach((el) => {
			(el as HTMLElement).style.setProperty('color', isDark ? 'var(--color-accent)' : '#e53e3e', 'important');
		});

		// Style error messages
		document.querySelectorAll('.newsletter-form-wrapper .hs-error-msg, .newsletter-form-wrapper .hs-error-msgs label').forEach((el) => {
			(el as HTMLElement).style.setProperty('color', '#f56565', 'important');
		});
	}

	function cleanupObservers() {
		formObservers.forEach((obs) => obs.disconnect());
		formObservers = [];

		if (themeObserver) {
			themeObserver.disconnect();
			themeObserver = null;
		}
	}

	function observeFormContainers() {
		document.querySelectorAll('.newsletter-form-wrapper').forEach((container) => {
			const observer = new MutationObserver(() => {
				applyThemeToForms();
			});
			observer.observe(container, { childList: true, subtree: true });
			formObservers.push(observer);
		});
	}

	function loadHubSpotForm() {
		// Clean up any stale observers from previous page loads
		cleanupObservers();

		const containers = document.querySelectorAll('.newsletter-form-wrapper');
		if (containers.length === 0) return;

		// Set up fresh observers
		observeFormContainers();

		themeObserver = new MutationObserver(() => {
			applyThemeToForms();
			// Re-create forms with updated CSS when theme changes (iframe content can't be restyled from parent)
			containers.forEach((container) => {
				const el = container as HTMLElement;
				// Remove old form content
				el.innerHTML = '';
				// Re-create with fresh theme CSS
				(window as any).hbspt?.forms?.create(createFormConfig(el.id));
			});
		});
		themeObserver.observe(document.documentElement, {
			attributes: true,
			attributeFilter: ['data-theme'],
		});

		// Generate CSS for HubSpot iframe based on current theme
		function getHubSpotIframeCss(): string {
			const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
			if (isDark) {
				return `
					body { background: transparent !important; }
					label { color: rgba(255, 255, 255, 0.9) !important; font-size: 0.8125rem !important; font-weight: 500 !important; }
					.legal-consent-container label,
					.hs-form-booleancheckbox label { color: rgba(255, 255, 255, 0.7) !important; }
					.legal-consent-container p,
					.legal-consent-container span,
					.hs-richtext p,
					.hs-form-booleancheckbox-display span,
					p, li { color: rgba(255, 255, 255, 0.7) !important; }
					.hs-input:not([type='checkbox']):not([type='submit']) {
						background: rgba(255, 255, 255, 0.06) !important;
						color: #fff !important;
						border-color: rgba(255, 255, 255, 0.18) !important;
						border-radius: 0.5rem !important;
						padding: 0.75rem 1rem !important;
						font-size: 0.9375rem !important;
						font-family: 'Outfit', sans-serif !important;
					}
					.hs-input:not([type='checkbox']):not([type='submit']):focus {
						border-color: rgba(255, 255, 255, 0.35) !important;
						outline: none !important;
					}
					.hs-form-required { color: #f0a030 !important; }
					.legal-consent-container a { color: #f0a030 !important; }
					.hs-error-msg, .hs-error-msgs label { color: #f56565 !important; }
					.hs-submit input[type='submit'] {
						background: linear-gradient(135deg, #f0a030, #e88d1a) !important;
						color: #111 !important;
						border: none !important;
						padding: 0.75rem 2rem !important;
						border-radius: 0.5rem !important;
						font-weight: 600 !important;
						cursor: pointer !important;
					}
				`;
			}
			return `
				body { background: transparent !important; }
				label { color: rgba(0, 0, 0, 0.65) !important; font-size: 0.8125rem !important; font-weight: 500 !important; }
				.legal-consent-container label,
				.hs-form-booleancheckbox label { color: rgba(0, 0, 0, 0.45) !important; }
				.legal-consent-container p,
				.legal-consent-container span,
				.hs-richtext p,
				.hs-form-booleancheckbox-display span,
				p, li { color: rgba(0, 0, 0, 0.45) !important; }
				.hs-input:not([type='checkbox']):not([type='submit']) {
					background: #fff !important;
					color: #111 !important;
					border-color: rgba(0, 0, 0, 0.15) !important;
					border-radius: 0.5rem !important;
					padding: 0.75rem 1rem !important;
					font-size: 0.9375rem !important;
					font-family: 'Outfit', sans-serif !important;
				}
				.hs-form-required { color: #f0a030 !important; }
				.legal-consent-container a { color: #f0a030 !important; }
				.hs-submit input[type='submit'] {
					background: linear-gradient(135deg, #f0a030, #e88d1a) !important;
					color: #111 !important;
					border: none !important;
					padding: 0.75rem 2rem !important;
					border-radius: 0.5rem !important;
					font-weight: 600 !important;
					cursor: pointer !important;
				}
			`;
		}

		// Shared form config with theme-aware CSS injection into iframe
		const createFormConfig = (targetId: string) => ({
			portalId: '4269433',
			formId: '956ea893-2ec8-43b0-a44e-a31b199800f3',
			region: 'na1',
			target: `#${targetId}`,
			css: getHubSpotIframeCss(),
			onFormReady: () => {
				// Also try to style content rendered outside the iframe
				applyThemeToForms();
				setTimeout(applyThemeToForms, 100);
				setTimeout(applyThemeToForms, 500);

				// Try to inject styles into iframe contentDocument (if same-origin)
				try {
					const wrapper = document.getElementById(targetId);
					const iframe = wrapper?.querySelector('iframe.hs-form-iframe') as HTMLIFrameElement;
					if (iframe?.contentDocument) {
						const iframeDoc = iframe.contentDocument;
						let styleEl = iframeDoc.getElementById('eddi-theme-override');
						if (!styleEl) {
							styleEl = iframeDoc.createElement('style');
							styleEl.id = 'eddi-theme-override';
							iframeDoc.head.appendChild(styleEl);
						}
						styleEl.textContent = getHubSpotIframeCss();
					}
				} catch (_e) { /* cross-origin — css param handles this */ }
			},
		});

		if (typeof (window as any).hbspt !== 'undefined') {
			containers.forEach((container) => {
				if (!container.querySelector('form') && !container.querySelector('.hs-form-iframe')) {
					(window as any).hbspt.forms.create(createFormConfig(container.id));
				}
			});
			return;
		}

		const script = document.createElement('script');
		script.src = '//js.hsforms.net/forms/embed/v2.js';
		script.async = true;
		script.onload = () => {
			containers.forEach((container) => {
				(window as any).hbspt.forms.create(createFormConfig(container.id));
			});
		};
		document.head.appendChild(script);
	}

	loadHubSpotForm();
	document.addEventListener('astro:page-load', loadHubSpotForm);
</script>

<style>
	.newsletter-section {
		position: relative;
		padding: 5rem 1.5rem;
		max-width: 72rem;
		margin: 0 auto;
		border-top: 1px solid rgba(128, 128, 128, 0.15);
	}

	.newsletter-glow {
		position: absolute;
		top: 50%;
		inset-inline-start: 50%;
		transform: translate(-50%, -50%);
		width: 60%;
		height: 60%;
		border-radius: 50%;
		pointer-events: none;
		z-index: -1;
	}

	html[data-theme='dark'] .newsletter-glow {
		background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 8%, transparent), transparent 70%);
	}
	html[data-theme='light'] .newsletter-glow {
		background: radial-gradient(ellipse, color-mix(in srgb, var(--color-accent) 5%, transparent), transparent 70%);
	}

	.newsletter-inner {
		max-width: 38rem;
		margin: 0 auto;
		text-align: center;
	}

	.newsletter-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 1rem;
		margin-bottom: 1.5rem;
		border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		color: var(--color-accent);
		box-shadow: 0 0 30px color-mix(in srgb, var(--color-accent) 15%, transparent);
	}

	.newsletter-icon svg {
		width: 1.5rem;
		height: 1.5rem;
	}

	.newsletter-title {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 0.75rem;
		border: 0 !important;
	}

	html[data-theme='dark'] .newsletter-title { color: #fff; }
	html[data-theme='light'] .newsletter-title { color: #111; }

	.newsletter-desc {
		font-size: 1rem;
		line-height: 1.6;
		margin: 0 0 2rem;
		max-width: 28rem;
		margin-inline: auto;
	}

	html[data-theme='dark'] .newsletter-desc { color: rgba(255, 255, 255, 0.5); }
	html[data-theme='light'] .newsletter-desc { color: rgba(0, 0, 0, 0.55); }

	.newsletter-form-wrapper {
		max-width: 28rem;
		margin: 0 auto;
		text-align: start;
		padding: 2rem;
		border-radius: 1rem;
	}

	html[data-theme='dark'] .newsletter-form-wrapper {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}
	html[data-theme='light'] .newsletter-form-wrapper {
		background: rgba(0, 0, 0, 0.02);
		border: 1px solid rgba(0, 0, 0, 0.06);
	}

	/*
	 * CSS-level dark mode overrides for HubSpot form elements.
	 * These act as a safety net — the JS theming handles most styling,
	 * but HubSpot sometimes re-injects elements after MutationObserver fires.
	 * Keep these values in sync with applyThemeToForms() above.
	 */
	html[data-theme='dark'] .newsletter-form-wrapper :global(label) {
		color: rgba(255, 255, 255, 0.9) !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.legal-consent-container label),
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hs-form-booleancheckbox label) {
		color: rgba(255, 255, 255, 0.7) !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.legal-consent-container p),
	html[data-theme='dark'] .newsletter-form-wrapper :global(.legal-consent-container span),
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hs-richtext p),
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hs-form-booleancheckbox-display span) {
		color: rgba(255, 255, 255, 0.7) !important;
	}
	/* Blanket catch-all for any HubSpot-injected text nodes */
	html[data-theme='dark'] .newsletter-form-wrapper :global(p),
	html[data-theme='dark'] .newsletter-form-wrapper :global(span:not(.hs-form-required)),
	html[data-theme='dark'] .newsletter-form-wrapper :global(li) {
		color: rgba(255, 255, 255, 0.7) !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hs-input:not([type="checkbox"])) {
		background: rgba(255, 255, 255, 0.06) !important;
		color: #fff !important;
		border-color: rgba(255, 255, 255, 0.18) !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.legal-consent-container a) {
		color: var(--color-accent) !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hubspot-link__container),
	html[data-theme='light'] .newsletter-form-wrapper :global(.hubspot-link__container) {
		display: none !important;
	}
	html[data-theme='dark'] .newsletter-form-wrapper :global(.hs-form-required) {
		color: var(--color-accent) !important;
	}

	@media (max-width: 30rem) {
		.newsletter-section {
			padding: 3rem 1.5rem;
		}

		.newsletter-title {
			font-size: 1.5rem;
		}

		.newsletter-form-wrapper {
			padding: 1.25rem;
		}
	}
</style>
