---
/**
 * Page layout for feature/enterprise/content subpages.
 * Provides a hero banner and centered content column.
 */
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description?: string;
	heroImage?: ImageMetadata;
	heroImageAlt?: string;
}

const { title, description, heroImage, heroImageAlt = '' } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<!-- Page Hero -->
	<section class="page-hero">
		<div class="page-hero-inner">
			<div class="page-hero-text">
				<h1>{title}</h1>
				{description && <p class="page-hero-tagline">{description}</p>}
			</div>
			{heroImage && (
				<div class="page-hero-image">
					<Image
						src={heroImage}
						alt={heroImageAlt}
						width={500}
						height={350}
						loading="eager"
						decoding="async"
					/>
				</div>
			)}
		</div>
	</section>

	<!-- Page Content -->
	<article class="page-article">
		<slot />
	</article>
</BaseLayout>

<style>
	.page-hero {
		width: 100vw;
		position: relative;
		left: 50%;
		right: 50%;
		margin-left: -50vw;
		margin-right: -50vw;
		padding: calc(var(--nav-height, 4rem) + 3rem) 1.5rem 3rem;
	}

	html[data-theme='dark'] .page-hero {
		background: linear-gradient(180deg, rgba(3, 3, 5, 1) 0%, rgba(15, 15, 25, 1) 100%);
	}

	html[data-theme='light'] .page-hero {
		background: linear-gradient(180deg, #f8f9fb 0%, #eef0f4 100%);
	}

	.page-hero-inner {
		max-width: 72rem;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 3rem;
	}

	.page-hero-text {
		flex: 1;
	}

	.page-hero-text h1 {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		line-height: 1.15;
		margin: 0 0 1rem;
	}

	html[data-theme='dark'] .page-hero-text h1 {
		color: #fff;
	}
	html[data-theme='light'] .page-hero-text h1 {
		color: #111;
	}

	.page-hero-tagline {
		font-size: 1.125rem;
		line-height: 1.65;
		margin: 0;
		max-width: 36rem;
	}

	html[data-theme='dark'] .page-hero-tagline {
		color: rgba(255, 255, 255, 0.6);
	}
	html[data-theme='light'] .page-hero-tagline {
		color: rgba(0, 0, 0, 0.6);
	}

	.page-hero-image {
		flex-shrink: 0;
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
	}

	.page-hero-image img {
		display: block;
		width: 100%;
		height: auto;
	}

	.page-article {
		max-width: 52rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 6rem;
		line-height: 1.75;
	}

	html[data-theme='dark'] .page-article {
		color: rgba(255, 255, 255, 0.8);
	}
	html[data-theme='light'] .page-article {
		color: rgba(0, 0, 0, 0.8);
	}

	@media (max-width: 50rem) {
		.page-hero-inner {
			flex-direction: column;
			text-align: center;
		}
		.page-hero-tagline {
			max-width: none;
		}
		.page-hero-image {
			max-width: 20rem;
		}
	}
</style>
