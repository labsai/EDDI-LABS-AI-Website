---
import FeaturePage from '../../../layouts/FeaturePage.astro';
import heroImage from '../../../assets/hero_performance.webp';
import { NON_DEFAULT_LOCALES, getTranslations, type Locale } from '../../../i18n';

export async function getStaticPaths() {
	return NON_DEFAULT_LOCALES.map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const t = await getTranslations(lang);
const p = t.pages.performance;
---
<FeaturePage title={p.title} description={p.description} heroImage={heroImage} lang={lang}>
<h2>{p.heading1}</h2><p set:html={p.para1} />

<!-- Why Virtual Threads Matter for AI -->
<h3>{p.vtTitle}</h3>
<p set:html={p.vtPara} />
<p set:html={p.vtPara2} />

<!-- Performance Highlights -->
<h2>{p.heading2}</h2>
<ul>{p.items.map((item) => <li set:html={item} />)}</ul>

<!-- Benchmark Context -->
<h3>{p.benchTitle}</h3>
<p set:html={p.benchPara} />
<p set:html={p.benchPara2} />
</FeaturePage>
