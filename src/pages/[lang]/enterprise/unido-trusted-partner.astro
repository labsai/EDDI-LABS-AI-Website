---
import UnidoPartnerContent from '../../../components/pages/UnidoPartnerContent.astro';
import { NON_DEFAULT_LOCALES, getTranslations, type Locale } from '../../../i18n';

export async function getStaticPaths() {
	return NON_DEFAULT_LOCALES.map((lang: Locale) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Locale };
const t = await getTranslations(lang);
---
<UnidoPartnerContent lang={lang} t={t} />
