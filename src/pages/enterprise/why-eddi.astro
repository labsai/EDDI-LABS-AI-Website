---
import FeaturePage from '../../layouts/FeaturePage.astro';
import heroImage from '../../assets/hero_why_eddi.webp';
import { enTranslations as t, localePath } from '../../i18n';
import { solutionsUrl, SOLUTIONS_LIVE } from '../../config';
const p = t.pages.whyEddi;
const enterpriseCtaHref = SOLUTIONS_LIVE ? solutionsUrl('en') : localePath('en', '/contact/');
---
<FeaturePage title={p.title} description={p.description} heroImage={heroImage} lang="en">
<h2>{p.heading1}</h2><p set:html={p.para1} />
<h2>{p.heading2}</h2><p set:html={p.para2} />
<ul>{p.items.map((item) => <li set:html={item} />)}</ul>
<h2>{p.heading3}</h2><ul>{p.items2.map((item) => <li set:html={item} />)}</ul>

<h2>{p.comparisonTitle}</h2>
<div class="overflow-x-auto mb-8">
<table>
<thead><tr><th>{p.comparisonHeaders.dimension}</th><th>{p.comparisonHeaders.frameworks}</th><th>{p.comparisonHeaders.eddi}</th></tr></thead>
<tbody>{p.comparisonRows.map((row) => <tr><td><strong>{row.dimension}</strong></td><td>{row.frameworks}</td><td>{row.eddi}</td></tr>)}</tbody>
</table>
</div>

<h2>{p.llmTitle}</h2>
<p>{p.llmDesc}</p>
<div class="overflow-x-auto mb-8">
<table>
<thead><tr><th>{p.llmHeaderCategory}</th><th>{p.llmHeaderProviders}</th></tr></thead>
<tbody>{p.llmCategories.map((cat) => <tr><td><strong>{cat.category}</strong></td><td>{cat.providers}</td></tr>)}</tbody>
</table>
</div>

<!-- RFP Evaluation Checklist -->
<h2>{p.rfpTitle}</h2>
<p>{p.rfpDesc}</p>
<div class="rfp-grid">
{p.rfpItems.map((item) => (
<div class="rfp-card">
	<div class="rfp-category">{item.category}</div>
	<div class="rfp-question">{item.question}</div>
	<div class="rfp-answer"><strong>EDDI:</strong> {item.eddiAnswer}</div>
</div>
))}
</div>

<!-- TCO: Build vs. Deploy -->
<h2>{p.tcoTitle}</h2>
<p set:html={p.tcoDesc} />
<div class="tco-comparison">
<div class="tco-column tco-build">
	<h3>{p.tcoBuildTitle}</h3>
	<ul>{p.tcoBuildItems.map((item) => <li set:html={item} />)}</ul>
</div>
<div class="tco-column tco-deploy">
	<h3>{p.tcoDeployTitle}</h3>
	<ul>{p.tcoDeployItems.map((item) => <li>{item}</li>)}</ul>
</div>
</div>

<!-- ROI -->
<h2>{p.roiTitle}</h2>
<p set:html={p.roiPara} />
<p set:html={p.roiPara2} />

<!-- Enterprise & Commercial CTA -->
<div class="enterprise-cta">
	<h2>{t.common.enterpriseCtaTitle}</h2>
	<p>{t.common.enterpriseCtaDesc}</p>
	<a href={enterpriseCtaHref} class="btn-cta-outline" target={SOLUTIONS_LIVE ? '_blank' : undefined} rel={SOLUTIONS_LIVE ? 'noopener' : undefined}>{t.common.enterpriseCtaBtn}</a>
</div>

</FeaturePage>

<style>
/* RFP Evaluation Grid */
.rfp-grid {
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
	gap: 1.25rem;
	margin: 1.5rem 0 2rem;
}
.rfp-card {
	background: var(--color-surface-elevated, rgba(255, 255, 255, 0.03));
	border: 1px solid var(--color-border);
	border-radius: 0.75rem;
	padding: 1.25rem;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
	transition: border-color 0.2s ease;
}
.rfp-card:hover {
	border-color: var(--color-accent, hsl(45, 100%, 51%));
}
.rfp-category {
	font-size: 0.75rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	color: var(--color-accent, hsl(45, 100%, 51%));
}
.rfp-question {
	font-size: 1rem;
	font-weight: 600;
	color: var(--color-text);
	line-height: 1.4;
}
.rfp-answer {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	line-height: 1.6;
	margin-top: 0.25rem;
}

/* TCO Comparison */
.tco-comparison {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1.5rem;
	margin: 1.5rem 0 2rem;
}
.tco-column {
	background: var(--color-surface-elevated, rgba(255, 255, 255, 0.03));
	border: 1px solid var(--color-border);
	border-radius: 0.75rem;
	padding: 1.5rem;
}
.tco-column h3 {
	margin-top: 0 !important;
}
.tco-build {
	opacity: 0.85;
}
.tco-deploy {
	border-color: var(--color-accent, hsl(45, 100%, 51%));
}

@media (max-width: 40rem) {
	.tco-comparison {
		grid-template-columns: 1fr;
	}
	.rfp-grid {
		grid-template-columns: 1fr;
	}
}

/* Enterprise & Commercial CTA */
.enterprise-cta {
	margin-top: 3rem;
	padding: 2.5rem 2rem;
	border-radius: 1rem;
	border: 1px solid color-mix(in srgb, var(--color-accent, hsl(45, 100%, 51%)) 35%, transparent);
	background: var(--color-surface-elevated, rgba(255, 255, 255, 0.03));
	text-align: center;
}
.enterprise-cta h2 {
	margin-top: 0 !important;
}
.enterprise-cta p {
	max-width: 38rem;
	margin: 0 auto 1.5rem;
}
</style>
