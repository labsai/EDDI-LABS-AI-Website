---
import FeaturePage from '../../layouts/FeaturePage.astro';
import heroImage from '../../assets/hero_security.webp';
import { enTranslations as t } from '../../i18n';
const p = t.pages.security;
---
<FeaturePage title={p.title} description={p.description} heroImage={heroImage} lang="en">
<h2>{p.heading1}</h2><p set:html={p.para1} />

<!-- Industry Context -->
<h3>{p.crisisTitle}</h3>
<p set:html={p.crisisPara} />
<p set:html={p.crisisPara2} />

<!-- Architectural Defense -->
<h3>{p.defenseTitle}</h3>
<p set:html={p.defensePara} />

<!-- Security Capabilities -->
<h2>{p.heading2}</h2>
<ul>{p.items.map((item) => <li set:html={item} />)}</ul>

<!-- Governance -->
<h3>{p.govTitle}</h3>
<p set:html={p.govPara} />
</FeaturePage>
