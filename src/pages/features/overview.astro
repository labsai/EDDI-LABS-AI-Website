---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/hero_features_overview.png';
---

<BaseLayout title="Features at a Glance" description="Every capability that makes EDDI the enterprise AI orchestrator — EDDI Manager UI, config-as-code, 48 MCP tools, security-first architecture, and more." fullWidth={true}>

<section class="fo-hero hero-gradient hero-gradient-bg">
	<div class="fo-hero-inner">
		<div class="fo-hero-text">
			<h1>Everything You Need to <span class="text-gradient-dynamic">Orchestrate AI</span></h1>
			<p>EDDI provides a complete, production-ready platform for building, deploying, and managing AI agents — without writing boilerplate.</p>
			<div class="fo-hero-actions">
				<a href="/getting-started/" class="btn-cta-primary">Get Started →</a>
				<a href="https://github.com/labsai/EDDI" class="btn-cta-outline" target="_blank" rel="noopener">View on GitHub ↗</a>
			</div>
		</div>
		<div class="fo-hero-image">
			<Image src={heroImage} alt="EDDI Features" width={480} height={320} loading="eager" decoding="async" />
		</div>
	</div>
</section>

<!-- Core Platform -->
<section class="py-24 max-w-7xl mx-auto px-6">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">Core Platform</h2>
		<p class="text-xl text-zinc-400 max-w-3xl mx-auto font-light leading-relaxed">The essential capabilities that make EDDI a <strong>complete AI orchestration platform</strong>.</p>
	</div>

	<div class="not-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
		<a href="/features/manager/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🖥️ EDDI Manager</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">A <strong>production-ready React UI</strong> for building, deploying, and monitoring agents visually — with 11-locale i18n, live chat debugging, and audit dashboards.</p>
		</a>
		<a href="/features/config-as-code/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">⚙️ Config-as-Code</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">Agent logic is JSON configuration, not compiled code. Prompt engineers iterate instantly — <strong>no recompilation needed</strong>.</p>
		</a>
		<a href="/features/mcp-server/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🔌 MCP Server (48 Tools)</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">Full AI-native control via the <strong>Model Context Protocol</strong>. Claude Desktop, Cursor, and custom clients manage agents programmatically.</p>
		</a>
		<a href="/features/security/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🔐 Security-First</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">No <code>eval()</code>, vault integration, path traversal protection, OIDC/Keycloak, <strong>cryptographic audit trails</strong>.</p>
		</a>
		<a href="/features/performance/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🚀 Performance</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">Java 25 Virtual Threads on Quarkus — <strong>millions of lightweight threads</strong> for I/O-bound LLM workloads.</p>
		</a>
		<a href="/features/multi-agent/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🤖 Multi-Agent</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">Intent-based agent discovery, managed conversations, agent triggers, and <strong>A/B routing</strong> across multiple agents.</p>
		</a>
	</div>
</section>

<!-- Engineering -->
<section class="py-24 max-w-7xl mx-auto px-6 border-t border-zinc-800/60">
	<div class="text-center mb-16">
		<h2 class="text-3xl md:text-5xl font-bold mb-6 text-white! border-0! text-center">Engineering Excellence</h2>
	</div>

	<div class="not-content grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
		<a href="/features/observability/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">📊 Observability</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">Every pipeline step logged with <strong>immutable audit trails</strong> — tokens, cost, timing, and tool calls.</p>
		</a>
		<a href="/features/code-quality/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🧪 Code Quality</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow"><strong>1,500+ tests with zero failures.</strong> Checkstyle reduced from 697 to 81 warnings. CI/CD enforced on every merge.</p>
		</a>
		<a href="/features/ai-ready/" class="relative overflow-hidden flex flex-col h-full p-8 rounded-3xl bg-zinc-900/40 backdrop-blur border border-zinc-700/50 hover:border-accent-500/50 transition-all duration-300 hover:-translate-y-2 shadow-xl group no-underline">
			<h3 class="text-xl font-bold text-white mb-3">🧩 AI-Ready</h3>
			<p class="text-zinc-400 text-sm leading-relaxed grow">48 MCP tools, predictable CRUD patterns, self-documenting APIs. <strong>Built for coding agents</strong> to work with.</p>
		</a>
	</div>
</section>

</BaseLayout>

<style>
	.fo-hero {
		padding: calc(var(--nav-height, 4rem) + 3rem) 1.5rem 3rem;
	}

	.fo-hero-inner {
		max-width: 72rem;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 3rem;
	}

	.fo-hero-text { flex: 1; }

	.fo-hero-text h1 {
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		line-height: 1.15;
		margin: 0 0 1rem;
		color: var(--color-text);
	}

	.fo-hero-text p {
		font-size: 1.125rem;
		line-height: 1.65;
		margin: 0 0 2rem;
		max-width: 36rem;
		color: var(--color-text-muted);
	}

	.fo-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

	.fo-hero-image {
		flex-shrink: 0;
		border-radius: 1rem;
		overflow: hidden;
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
	}

	.fo-hero-image img { display: block; width: 100%; height: auto; max-width: 28rem; }

	@media (max-width: 50rem) {
		.fo-hero-inner { flex-direction: column; text-align: center; }
		.fo-hero-actions { justify-content: center; }
		.fo-hero-image { max-width: 20rem; }
	}
</style>


