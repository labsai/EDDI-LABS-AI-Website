---
import FeaturePage from '../../layouts/FeaturePage.astro';
import heroImage from '../../assets/hero_performance.webp';
import { enTranslations as t } from '../../i18n';
const p = t.pages.performance;
---
<FeaturePage title={p.title} description={p.description} heroImage={heroImage} lang="en">
<h2>{p.heading1}</h2><p set:html={p.para1} />

<!-- Why Virtual Threads Matter for AI -->
<h3>{p.vtTitle}</h3>
<p set:html={p.vtPara} />
<p set:html={p.vtPara2} />

<!-- Performance Highlights -->
<h2>{p.heading2}</h2>
<ul>{p.items.map((item) => <li set:html={item} />)}</ul>

<!-- Benchmark Context -->
<h3>{p.benchTitle}</h3>
<p set:html={p.benchPara} />
<p set:html={p.benchPara2} />
</FeaturePage>
