---
import '../styles/global.css';
import { isRTL } from '../i18n';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  userEmail?: string | null;
}

const {
  title = 'EDDI Cloud',
  description = 'Your dedicated EDDI AI orchestration instance on Google Cloud.',
  lang = 'en',
  userEmail = null,
} = Astro.props;

const dir = isRTL(lang) ? 'rtl' : 'ltr';
const fullTitle = title === 'EDDI Cloud' ? 'EDDI Cloud' : `${title} — EDDI Cloud`;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang} dir={dir} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        var s = localStorage.getItem('theme');
        var p = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.dataset.theme = s || p;
      })();
    </script>
  </head>
  <body>
    <header class="portal-header">
      <div class="portal-header-inner">
        <a href="/" class="portal-logo" aria-label="EDDI Cloud home">
          <svg width="26" height="26" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" style="fill: var(--color-accent, #7c3aed)" />
            <text x="16" y="22" text-anchor="middle" font-family="inherit" font-size="14" font-weight="800" fill="white">E</text>
          </svg>
          <span>EDDI <span class="text-accent">Cloud</span></span>
        </a>

        <nav class="portal-nav">
          {userEmail ? (
            <span class="nav-email">{userEmail}</span>
            <a href="/dashboard" class="nav-link">Dashboard</a>
            <form method="POST" action="/api/auth/logout" style="display:contents">
              <button type="submit" class="nav-link">Sign out</button>
            </form>
          ) : (
            <a href="https://eddi.labs.ai" class="nav-back">← eddi.labs.ai</a>
            <a href="/login" class="nav-link">Sign in</a>
            <a href="/register" class="nav-cta">Get started</a>
          )}
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" type="button">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="portal-footer">
      <div class="portal-footer-inner">
        <span>© {year} LABS.AI · <a href="https://eddi.labs.ai" class="footer-link">eddi.labs.ai</a></span>
        <div style="display:flex;gap:1.5rem">
          <a href="https://docs.labs.ai" target="_blank" rel="noopener" class="footer-link">Docs</a>
          <a href="mailto:support@labs.ai" class="footer-link">Support</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var html = document.documentElement;
          var next = html.dataset.theme === 'dark' ? 'light' : 'dark';
          html.dataset.theme = next;
          localStorage.setItem('theme', next);
        });
      }
    </script>
  </body>
</html>

<style>
  .portal-header {
    position: sticky; top: 0; z-index: 100;
    padding: 0 1.5rem; height: 3.5rem;
    background: rgba(10, 10, 15, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  html[data-theme='light'] .portal-header {
    background: rgba(248, 247, 255, 0.92);
  }
  .portal-header-inner {
    max-width: 72rem; margin: 0 auto; height: 100%;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .portal-logo {
    display: flex; align-items: center; gap: 0.5rem;
    text-decoration: none; font-weight: 700; font-size: 1rem;
    color: var(--color-text);
  }
  .text-accent { color: var(--color-accent, #7c3aed); }

  .portal-nav { display: flex; align-items: center; gap: 0.375rem; }

  .nav-email {
    font-size: 0.8125rem; color: var(--color-text-muted);
    max-width: 12rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    padding: 0 0.5rem;
  }
  .nav-back {
    font-size: 0.8125rem; color: var(--color-text-muted);
    text-decoration: none; padding: 0.4rem 0.625rem;
    transition: color 0.15s;
  }
  .nav-back:hover { color: var(--color-text); }

  .nav-link {
    font-size: 0.8125rem; color: var(--color-text-muted);
    text-decoration: none; padding: 0.4rem 0.625rem;
    border-radius: 0.375rem; border: none; background: none;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover {
    color: var(--color-text);
    background: rgba(124, 58, 237, 0.08);
  }
  .nav-cta {
    font-size: 0.8125rem; font-weight: 600; text-decoration: none;
    padding: 0.4rem 0.875rem; border-radius: 0.375rem;
    background: var(--color-accent, #7c3aed); color: #fff;
    transition: opacity 0.15s;
  }
  .nav-cta:hover { opacity: 0.88; }

  .theme-btn {
    display: flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem; border-radius: 0.375rem;
    border: none; background: none; color: var(--color-text-muted);
    margin-inline-start: 0.125rem; transition: color 0.15s, background 0.15s;
  }
  .theme-btn:hover { color: var(--color-text); background: rgba(124, 58, 237, 0.08); }
  html[data-theme='dark']  .icon-sun  { display: none; }
  html[data-theme='light'] .icon-moon { display: none; }

  .portal-footer {
    padding: 1.5rem; border-top: 1px solid var(--color-border);
  }
  .portal-footer-inner {
    max-width: 72rem; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; font-size: 0.875rem; color: var(--color-text-muted); flex-wrap: wrap;
  }
  .footer-link { color: var(--color-text-muted); text-decoration: none; transition: color 0.15s; }
  .footer-link:hover { color: var(--color-text); }
</style>
