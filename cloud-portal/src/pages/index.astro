---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getT } from '../i18n';
import { createSupabaseServerClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

const t = await getT(Astro.locals.lang);

const priceMonthly = import.meta.env.PUBLIC_PADDLE_PRICE_ID_MONTHLY;
const priceYearly  = import.meta.env.PUBLIC_PADDLE_PRICE_ID_YEARLY;
const paddleToken  = import.meta.env.PUBLIC_PADDLE_CLIENT_TOKEN;
const paddleEnv    = import.meta.env.PUBLIC_PADDLE_ENV;
---

<BaseLayout title="EDDI Cloud" lang={Astro.locals.lang} userEmail={user?.email ?? null}>

  <!-- Hero -->
  <section class="hero">
    <div class="inner">
      <div class="badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
        {t.pricing.badge}
      </div>
      <h1>{t.pricing.headline}</h1>
      <p class="sub">{t.pricing.subheadline}</p>
    </div>
  </section>

  <!-- Toggle -->
  <section class="pricing-wrap">
    <div class="inner">
      <div class="toggle" role="group" aria-label="Billing period">
        <button id="btn-monthly" class="toggle-btn active" type="button">{t.pricing.toggleMonthly}</button>
        <button id="btn-yearly"  class="toggle-btn"        type="button">
          {t.pricing.toggleYearly}
          <span class="save-badge">{t.pricing.saveBadge}</span>
        </button>
      </div>

      <!-- Cards -->
      <div class="cards">
        <!-- Monthly -->
        <div class="card" id="panel-monthly">
          <p class="plan-label">{t.pricing.monthly.label}</p>
          <div class="price-row">
            <span class="price-amount">{t.pricing.monthly.price}</span>
            <span class="price-period">{t.pricing.monthly.period}</span>
          </div>
          <p class="plan-desc">{t.pricing.monthly.description}</p>
          <ul class="features">
            {t.pricing.features.map((f: string) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          {user
            ? <button class="cta" data-plan="monthly" data-price={priceMonthly} data-uid={user.id} data-email={user.email}>{t.pricing.monthly.cta}</button>
            : <a href="/register" class="cta">{t.pricing.monthly.cta}</a>
          }
        </div>

        <!-- Yearly (featured) -->
        <div class="card card-featured hidden" id="panel-yearly">
          <div class="featured-ribbon">{t.pricing.saveBadge}</div>
          <p class="plan-label featured-label">{t.pricing.yearly.label}</p>
          <div class="price-row">
            <span class="price-amount">{t.pricing.yearly.price}</span>
            <span class="price-period">{t.pricing.yearly.period}</span>
          </div>
          <p class="price-billed">{t.pricing.yearly.billedAs}</p>
          <p class="plan-desc">{t.pricing.yearly.description}</p>
          <ul class="features">
            {t.pricing.features.map((f: string) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          {user
            ? <button class="cta cta-featured" data-plan="yearly" data-price={priceYearly} data-uid={user.id} data-email={user.email}>{t.pricing.yearly.cta}</button>
            : <a href="/register" class="cta cta-featured">{t.pricing.yearly.cta}</a>
          }
        </div>
      </div>

      {!user && (
        <p class="signin-hint">
          {t.pricing.alreadyCustomer} <a href="/login">{t.pricing.signIn}</a>
        </p>
      )}
    </div>
  </section>
</BaseLayout>

{user && (
  <script define:vars={{ paddleToken, paddleEnv, priceMonthly, priceYearly }}>
    (function () {
      var paddleReady = false;

      var script = document.createElement('script');
      script.src = 'https://cdn.paddle.com/paddle/v2/paddle.js';
      script.onerror = function () {
        console.error('[Paddle] Failed to load paddle.js');
      };
      script.onload = function () {
        if (paddleEnv === 'sandbox') Paddle.Environment.set('sandbox');
        Paddle.Initialize({
          token: paddleToken,
          eventCallback: function (ev) {
            if (ev.name === 'checkout.error') {
              console.error('[Paddle] Checkout error:', ev.data);
              alert('Payment error: ' + (ev.data?.error?.detail || JSON.stringify(ev.data)));
            }
          },
        });
        paddleReady = true;
      };
      document.head.appendChild(script);

      document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-plan]');
        if (!btn) return;
        if (!paddleReady) {
          alert('Payment system is still loading. Please try again in a moment.');
          return;
        }
        try {
          Paddle.Checkout.open({
            items: [{ priceId: btn.dataset.price, quantity: 1 }],
            customer: { email: btn.dataset.email },
            customData: { userId: btn.dataset.uid },
            successUrl: window.location.origin + '/checkout/success',
          });
        } catch (err) {
          console.error('[Paddle] Checkout.open error:', err);
          alert('Could not open checkout: ' + err.message);
        }
      });
    })();
  </script>
)}

<script is:inline>
  var btnM = document.getElementById('btn-monthly');
  var btnY = document.getElementById('btn-yearly');
  var panM = document.getElementById('panel-monthly');
  var panY = document.getElementById('panel-yearly');
  if (btnM && btnY && panM && panY) {
    btnM.addEventListener('click', function () {
      btnM.classList.add('active'); btnY.classList.remove('active');
      panM.classList.remove('hidden'); panY.classList.add('hidden');
    });
    btnY.addEventListener('click', function () {
      btnY.classList.add('active'); btnM.classList.remove('active');
      panY.classList.remove('hidden'); panM.classList.add('hidden');
    });
  }
</script>

<style>
  .hero { padding: 5rem 1.5rem 2rem; text-align: center; }
  .inner { max-width: 48rem; margin: 0 auto; }

  .badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.3rem 0.75rem; border-radius: 999px;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 0.04em;
    background: rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(124, 58, 237, 0.3);
    color: #a78bfa; margin-bottom: 1.5rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800;
    line-height: 1.1; margin: 0 0 1.25rem;
    color: var(--color-text);
  }
  .sub {
    font-size: 1.125rem; color: var(--color-text-muted);
    line-height: 1.65; margin: 0;
  }

  .pricing-wrap { padding: 2rem 1.5rem 5rem; }
  .pricing-wrap .inner { max-width: 52rem; }

  .toggle {
    display: inline-flex; gap: 0.25rem;
    background: rgba(124, 58, 237, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem; padding: 0.25rem;
    margin-bottom: 2.5rem;
  }
  .toggle-btn {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.45rem 1rem; border-radius: 0.375rem;
    font-size: 0.9rem; font-weight: 500;
    border: none; background: none; color: var(--color-text-muted);
    transition: all 0.15s;
  }
  .toggle-btn.active {
    background: var(--color-accent, #7c3aed); color: #fff;
  }
  .toggle-btn:not(.active):hover { color: var(--color-text); }

  .save-badge {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.03em;
    padding: 0.15rem 0.45rem; border-radius: 999px;
    background: rgba(124, 58, 237, 0.18); color: #a78bfa;
  }
  .toggle-btn.active .save-badge { background: rgba(255,255,255,0.2); color: #fff; }

  .cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 40rem) { .cards { grid-template-columns: 1fr; } }

  .card {
    padding: 2rem; border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card, #111118);
    display: flex; flex-direction: column; gap: 0;
  }
  html[data-theme='light'] .card {
    background: #fff;
    box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  }
  .card-featured {
    background: linear-gradient(135deg, rgba(124,58,237,0.08) 0%, var(--color-bg-card, #111118) 60%);
    border-color: rgba(124, 58, 237, 0.4);
    box-shadow: 0 0 40px rgba(124,58,237,0.08);
  }
  .hidden { display: none !important; }

  .featured-ribbon {
    display: inline-block; align-self: flex-start;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em;
    padding: 0.2rem 0.6rem; border-radius: 999px; margin-bottom: 0.75rem;
    background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3); color: #a78bfa;
  }

  .plan-label { font-size: 0.8125rem; font-weight: 600; color: var(--color-text-muted); margin: 0 0 0.5rem; }
  .featured-label { color: #a78bfa; }

  .price-row { display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 0.25rem; }
  .price-amount { font-size: 2.5rem; font-weight: 800; color: var(--color-text); }
  .price-period { font-size: 0.9rem; color: var(--color-text-muted); }
  .price-billed  { font-size: 0.8rem; color: var(--color-text-muted); margin: 0 0 0.5rem; }
  .plan-desc { font-size: 0.875rem; color: var(--color-text-muted); margin: 0 0 1.5rem; }

  .features { list-style: none; padding: 0; margin: 0 0 2rem; display: flex; flex-direction: column; gap: 0.625rem; }
  .features li { display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.9rem; color: var(--color-text); }
  .features svg { width: 1rem; height: 1rem; flex-shrink: 0; color: #a78bfa; margin-top: 0.125rem; }

  .cta {
    display: block; width: 100%; padding: 0.75rem 1rem;
    border-radius: 0.5rem; font-size: 0.9375rem; font-weight: 600;
    text-align: center; text-decoration: none; border: none;
    background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.3);
    color: #a78bfa;
    transition: all 0.2s; margin-top: auto;
  }
  .cta:hover { background: rgba(124,58,237,0.2); border-color: rgba(124,58,237,0.5); }
  .cta-featured {
    background: var(--color-accent, #7c3aed); color: #fff; border-color: transparent;
    box-shadow: 0 0 24px rgba(124,58,237,0.3);
  }
  .cta-featured:hover { opacity: 0.9; box-shadow: 0 0 32px rgba(124,58,237,0.4); }

  .signin-hint {
    text-align: center; margin-top: 2rem;
    font-size: 0.9rem; color: var(--color-text-muted);
  }
  .signin-hint a { color: #a78bfa; text-decoration: none; }
  .signin-hint a:hover { text-decoration: underline; }
</style>
