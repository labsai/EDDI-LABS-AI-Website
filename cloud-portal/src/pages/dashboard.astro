---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getT } from '../i18n';
import { createSupabaseServerClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login?next=/dashboard');

const t = await getT(Astro.locals.lang);

const [profileRes, subsRes, paymentsRes] = await Promise.all([
  supabase.from('user_profiles').select('*').eq('id', user.id).single(),
  supabase.from('subscriptions').select('*').eq('user_id', user.id).order('created_at', { ascending: false }),
  supabase.from('payments').select('*').eq('user_id', user.id).order('created_at', { ascending: false }).limit(20),
]);

const profile      = profileRes.data;
const subscriptions = subsRes.data ?? [];
const payments      = paymentsRes.data ?? [];

const td = t.dashboard;
---

<BaseLayout title={td.title} lang={Astro.locals.lang} userEmail={user.email ?? null}>

  <div class="dash-layout">

    <!-- Instance Status Card -->
    <section class="dash-card">
      <h2 class="section-title">{td.instance.title}</h2>
      <div class="instance-grid">
        <div class="instance-row">
          <span class="instance-label">{td.instance.statusLabel}</span>
          <span class={`status-pill status-${profile?.gcp_instance_status ?? 'pending'}`}>
            {td.instance.statuses[profile?.gcp_instance_status as keyof typeof td.instance.statuses ?? 'pending']}
          </span>
        </div>
        {profile?.gcp_instance_url && (
          <div class="instance-row">
            <span class="instance-label">{td.instance.urlLabel}</span>
            <a href={profile.gcp_instance_url} target="_blank" rel="noopener" class="instance-url">
              {profile.gcp_instance_url}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        )}
        {!profile?.gcp_instance_url && profile?.gcp_instance_status === 'pending' && (
          <p class="instance-hint">{td.instance.pendingHint}</p>
        )}
        {profile?.gcp_instance_status === 'provisioning' && (
          <p class="instance-hint">{td.instance.provisioningHint}</p>
        )}
        {profile?.gcp_instance_status === 'failed' && (
          <p class="instance-hint hint-error">{td.instance.failedHint}</p>
        )}
      </div>
    </section>

    <!-- Subscriptions -->
    <section class="dash-card">
      <div class="section-header">
        <h2 class="section-title">{td.subscriptions.title}</h2>
        <a href="/" class="new-sub-btn">{td.newSubscription}</a>
      </div>

      {subscriptions.length === 0 ? (
        <p class="empty-state">{td.subscriptions.empty}</p>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>{td.subscriptions.plan}</th>
                <th>{td.subscriptions.status}</th>
                <th>{td.subscriptions.renewsOn}</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {subscriptions.map((sub) => {
                const planKey = sub.plan as keyof typeof td.subscriptions.plans;
                const statusKey = sub.status as keyof typeof td.subscriptions.statuses;
                const periodEnd = sub.current_period_end
                  ? new Date(sub.current_period_end).toLocaleDateString()
                  : '—';
                return (
                  <tr>
                    <td>{td.subscriptions.plans[planKey] ?? sub.plan}</td>
                    <td>
                      <span class={`status-pill status-${sub.status}`}>
                        {td.subscriptions.statuses[statusKey] ?? sub.status}
                      </span>
                    </td>
                    <td>{sub.cancel_at_period_end ? `${td.subscriptions.endsOn} ${periodEnd}` : periodEnd}</td>
                    <td>
                      {sub.status === 'active' && !sub.cancel_at_period_end && (
                        <button
                          class="cancel-btn"
                          data-sub-id={sub.id}
                          data-paddle-id={sub.paddle_subscription_id}
                          onclick="confirmCancel(this)"
                        >
                          {td.subscriptions.cancelButton}
                        </button>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- Payments -->
    <section class="dash-card">
      <h2 class="section-title">{td.payments.title}</h2>
      {payments.length === 0 ? (
        <p class="empty-state">{td.payments.empty}</p>
      ) : (
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>{td.payments.date}</th>
                <th>{td.payments.amount}</th>
                <th>{td.payments.status}</th>
              </tr>
            </thead>
            <tbody>
              {payments.map((p) => {
                const statusKey = p.status as keyof typeof td.payments.statuses;
                return (
                  <tr>
                    <td>{new Date(p.created_at).toLocaleDateString()}</td>
                    <td>{(p.amount_cents / 100).toFixed(2)} {p.currency}</td>
                    <td>
                      <span class={`status-pill status-${p.status}`}>
                        {td.payments.statuses[statusKey] ?? p.status}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>

  <!-- Cancel confirmation dialog -->
  <div id="cancel-dialog" class="dialog-overlay hidden" role="dialog" aria-modal="true">
    <div class="dialog-card">
      <h3 class="dialog-title">{td.subscriptions.cancelConfirmTitle}</h3>
      <p class="dialog-body">{td.subscriptions.cancelConfirmBody}</p>
      <div id="cancel-error" class="cancel-error hidden"></div>
      <div class="dialog-actions">
        <button id="cancel-no" class="dialog-btn-secondary" onclick="closeCancel()">{td.subscriptions.cancelNo}</button>
        <button id="cancel-yes" class="dialog-btn-danger" onclick="submitCancel()">{td.subscriptions.cancelYes}</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ cancelSuccessMsg: td.subscriptions.cancelSuccess, cancelErrorMsg: td.subscriptions.cancelError }}>
  var pendingSubId = null;
  var pendingPaddleId = null;

  window.confirmCancel = function (btn) {
    pendingSubId = btn.dataset.subId;
    pendingPaddleId = btn.dataset.paddleId;
    document.getElementById('cancel-dialog').classList.remove('hidden');
    document.getElementById('cancel-error').classList.add('hidden');
    document.getElementById('cancel-error').textContent = '';
    document.getElementById('cancel-yes').disabled = false;
  };
  window.closeCancel = function () {
    document.getElementById('cancel-dialog').classList.add('hidden');
    pendingSubId = null; pendingPaddleId = null;
  };
  window.submitCancel = async function () {
    if (!pendingSubId) return;
    var yesBtn = document.getElementById('cancel-yes');
    yesBtn.disabled = true;
    try {
      var res = await fetch('/api/subscriptions/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ subscriptionId: pendingSubId }),
      });
      if (res.ok) {
        closeCancel();
        window.location.reload();
      } else {
        var errEl = document.getElementById('cancel-error');
        errEl.textContent = cancelErrorMsg;
        errEl.classList.remove('hidden');
        yesBtn.disabled = false;
      }
    } catch {
      var errEl = document.getElementById('cancel-error');
      errEl.textContent = cancelErrorMsg;
      errEl.classList.remove('hidden');
      yesBtn.disabled = false;
    }
  };

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeCancel();
  });
</script>

<style>
  .dash-layout {
    max-width: 56rem; margin: 0 auto; padding: 2.5rem 1.5rem 4rem;
    display: flex; flex-direction: column; gap: 1.5rem;
  }

  .dash-card {
    padding: 1.75rem; border-radius: 1rem;
    background: var(--color-bg-card, #111118);
    border: 1px solid var(--color-border);
  }
  html[data-theme='light'] .dash-card {
    background: #fff; box-shadow: 0 1px 8px rgba(0,0,0,0.06);
  }

  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .section-title {
    font-size: 1rem; font-weight: 700; color: var(--color-text);
    margin: 0 0 1.25rem;
  }
  .section-header .section-title { margin-bottom: 0; }

  .new-sub-btn {
    font-size: 0.8125rem; font-weight: 600; text-decoration: none;
    padding: 0.4rem 0.875rem; border-radius: 0.375rem;
    background: rgba(124,58,237,0.12); border: 1px solid rgba(124,58,237,0.3);
    color: #a78bfa; transition: all 0.15s;
  }
  .new-sub-btn:hover { background: rgba(124,58,237,0.2); }

  .instance-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .instance-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .instance-label { font-size: 0.875rem; color: var(--color-text-muted); min-width: 6rem; }
  .instance-url {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.875rem; color: #a78bfa; text-decoration: none;
    font-family: monospace;
  }
  .instance-url:hover { text-decoration: underline; }
  .instance-hint { font-size: 0.85rem; color: var(--color-text-muted); margin: 0.5rem 0 0; }
  .hint-error { color: #f87171; }

  .status-pill {
    display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.02em;
    padding: 0.2rem 0.625rem; border-radius: 999px;
  }
  .status-active     { background: rgba(34,197,94,0.12);  color: #86efac; border: 1px solid rgba(34,197,94,0.25); }
  .status-canceled   { background: rgba(107,114,128,0.12); color: #9ca3af; border: 1px solid rgba(107,114,128,0.25); }
  .status-past_due   { background: rgba(239,68,68,0.12);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }
  .status-trialing   { background: rgba(59,130,246,0.12); color: #93c5fd; border: 1px solid rgba(59,130,246,0.25); }
  .status-paused     { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.25); }
  .status-provisioning { background: rgba(59,130,246,0.12); color: #93c5fd; border: 1px solid rgba(59,130,246,0.25); }
  .status-pending    { background: rgba(107,114,128,0.12); color: #9ca3af; border: 1px solid rgba(107,114,128,0.25); }
  .status-failed     { background: rgba(239,68,68,0.12);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.25); }
  .status-completed  { background: rgba(34,197,94,0.12);  color: #86efac; border: 1px solid rgba(34,197,94,0.25); }
  .status-refunded   { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.25); }

  .empty-state { font-size: 0.9rem; color: var(--color-text-muted); margin: 0; }

  .table-wrap { overflow-x: auto; }
  .data-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .data-table th {
    text-align: left; padding: 0.5rem 0.75rem;
    font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border); white-space: nowrap;
  }
  .data-table td {
    padding: 0.75rem; border-bottom: 1px solid rgba(124,58,237,0.06);
    color: var(--color-text); vertical-align: middle;
  }
  .data-table tr:last-child td { border-bottom: none; }

  .cancel-btn {
    font-size: 0.8rem; padding: 0.3rem 0.625rem;
    border-radius: 0.375rem; border: 1px solid rgba(239,68,68,0.3);
    background: rgba(239,68,68,0.08); color: #fca5a5;
    transition: all 0.15s;
  }
  .cancel-btn:hover { background: rgba(239,68,68,0.15); border-color: rgba(239,68,68,0.5); }

  .dialog-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center; padding: 1.5rem;
  }
  .dialog-overlay.hidden { display: none !important; }
  .dialog-card {
    width: 100%; max-width: 22rem; padding: 1.75rem; border-radius: 1rem;
    background: var(--color-bg-card, #18181b); border: 1px solid var(--color-border);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    animation: fadeIn 0.18s ease;
  }
  html[data-theme='light'] .dialog-card { background: #fff; }
  @keyframes fadeIn { from { opacity:0; transform: scale(0.96) } to { opacity:1; transform: scale(1) } }
  .dialog-title { font-size: 1.125rem; font-weight: 700; margin: 0 0 0.625rem; color: var(--color-text); }
  .dialog-body { font-size: 0.9rem; color: var(--color-text-muted); margin: 0 0 1.25rem; }
  .cancel-error {
    padding: 0.625rem 0.75rem; border-radius: 0.375rem; margin-bottom: 1rem;
    background: rgba(239,68,68,0.1); color: #fca5a5;
    font-size: 0.85rem; border: 1px solid rgba(239,68,68,0.3);
  }
  .cancel-error.hidden { display: none !important; }
  .dialog-actions { display: flex; gap: 0.625rem; justify-content: flex-end; }
  .dialog-btn-secondary {
    padding: 0.5rem 1rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 600;
    border: 1px solid var(--color-border); background: none; color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .dialog-btn-secondary:hover { color: var(--color-text); }
  .dialog-btn-danger {
    padding: 0.5rem 1rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 600;
    border: none; background: #dc2626; color: #fff; transition: opacity 0.15s;
  }
  .dialog-btn-danger:hover:not(:disabled) { opacity: 0.88; }
  .dialog-btn-danger:disabled { opacity: 0.5; cursor: not-allowed; }
</style>
