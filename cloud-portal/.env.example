# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Paddle ──────────────────────────────────────────────────────────────────
# "sandbox" for testing, "production" for live payments
PUBLIC_PADDLE_ENV=sandbox

# Client-side token — Paddle dashboard → Developer → Authentication
# Starts with "test_" in sandbox, "live_" in production
PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-side API key — Paddle dashboard → Developer → Authentication
PADDLE_API_KEY=pdl_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret — Paddle dashboard → Notifications → Endpoints → your endpoint
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs — create a product and two prices (monthly + yearly) in Paddle first
PUBLIC_PADDLE_PRICE_ID_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_PADDLE_PRICE_ID_YEARLY=pri_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Cloud Provisioning ───────────────────────────────────────────────
# HTTPS endpoint of your Cloud Run / Cloud Function that provisions EDDI instances
GCP_PROVISIONING_ENDPOINT=https://your-region-your-project.cloudfunctions.net/provision-eddi
GCP_PROVISIONING_SECRET=your-provisioning-shared-secret
